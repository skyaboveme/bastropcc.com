---
import BaseLayout from './BaseLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import CTABanner from '../components/ui/CTABanner.astro';

export interface Props {
  title: string;
  description?: string;
  heading?: string;
  subheading?: string;
}

const { title, description, heading = title, subheading } = Astro.props;
---

<BaseLayout title={title} description={description}>
  
  <header class="bg-bcc-cream border-b border-bcc-gray-200 py-12 md:py-20 px-4">
    <div class="max-w-7xl mx-auto text-center">
      <SectionHeading title={heading} subtitle={subheading} centered={true} />
    </div>
  </header>

  <section class="max-w-4xl mx-auto px-4 py-16 md:py-24 prose prose-lg prose-bcc prose-headings:font-serif prose-headings:text-bcc-navy prose-a:text-bcc-red hover:prose-a:text-bcc-red-dark">
    <slot />
  </section>
  
  <CTABanner />
</BaseLayout>
