---
import { generateOrganizationSchema } from '../../utils/schema';

export interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
}

const {
  title = 'Bastrop County Conservatives — Local Action = National Wins',
  description = "Bastrop County Conservatives is an organization focused on promoting core conservative values in our local government. We believe that there is a time when we must fight for what is right, and that time is now.",
  image = '/images/BCCLogo.jpg',
  article = false,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://bastropcc.com');
const imageUrl = new URL(image, Astro.site || 'https://bastropcc.com');
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="robots" content="index, follow" />
<meta name="theme-color" content="#1a2b4a" />
<meta name="geo.region" content="US-TX" />
<meta name="geo.placename" content="Bastrop County, Texas" />

<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<meta property="og:type" content={article ? 'article' : 'website'} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={imageUrl} />

<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={imageUrl} />

<script type="application/ld+json" set:html={generateOrganizationSchema()} />
