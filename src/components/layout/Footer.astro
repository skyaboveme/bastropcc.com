---
import { Icon } from 'astro-icon/components';
---

<footer class="bg-bcc-navy-dark text-white pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- Col 1: Brand & PAC Line -->
      <div class="space-y-6">
        <a href="/" class="flex items-center gap-3">
          <img src="/Assets/cropped-BCC-Final-Logo-1-w-Transparent-Background.png" alt="Bastrop County Conservatives" class="h-16 w-auto" onerror="this.src='/favicon.png'" />
          <div class="flex flex-col justify-center translate-y-0.5">
            <span class="font-serif font-bold text-base tracking-wide uppercase text-white leading-none">Bastrop County</span>
            <span class="font-serif font-bold text-base tracking-[0.09em] uppercase text-bcc-red leading-none">Conservatives</span>
          </div>
        </a>
        <p class="text-bcc-gray-200 text-sm leading-relaxed">
          Upholding the family values, faith, and traditions that have defined Bastrop County for over 250 years.
        </p>
        <div class="border border-bcc-gray-600 p-3 rounded bg-bcc-navy/50 inline-block">
          <p class="text-xs uppercase tracking-wider font-semibold text-bcc-gray-200">
            Political Advertising Paid For By Bastrop County Conservatives PAC
          </p>
        </div>
      </div>

      <!-- Col 2: Quick Links -->
      <div>
        <h3 class="font-serif text-xl font-bold mb-6 text-bcc-gold">Quick Links</h3>
        <ul class="space-y-4">
          <li><a href="/about" class="text-bcc-gray-200 hover:text-white transition-colors">About Us</a></li>
          <li><a href="/blog" class="text-bcc-gray-200 hover:text-white transition-colors">Blog</a></li>
          <li><a href="/membership" class="text-bcc-gray-200 hover:text-white transition-colors">Membership</a></li>
          <li><a href="/volunteer" class="text-bcc-gray-200 hover:text-white transition-colors">Volunteer</a></li>
          <li><a href="/donate" class="text-bcc-gray-200 hover:text-white transition-colors">Donate</a></li>
          <li><a href="/contact" class="text-bcc-gray-200 hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>

      <!-- Col 3: Voter Resources -->
      <div>
        <h3 class="font-serif text-xl font-bold mb-6 text-bcc-gold">Voter Resources</h3>
        <ul class="space-y-4">
          <li><a href="https://bastropvotes.org/" target="_blank" rel="noopener noreferrer" class="text-bcc-gray-200 hover:text-white transition-colors flex items-center gap-2">BastropVotes.org <Icon name="lucide:external-link" class="w-4 h-4" /></a></li>
          <li><a href="https://bastropvotes.org/voting-schedule/" target="_blank" rel="noopener noreferrer" class="text-bcc-gray-200 hover:text-white transition-colors flex items-center gap-2">Voting Locations <Icon name="lucide:external-link" class="w-4 h-4" /></a></li>
          <li><a href="/voter-info" class="text-bcc-gray-200 hover:text-white transition-colors">More Voter Info →</a></li>
        </ul>
      </div>

      <!-- Col 4: Follow Us & Subscribe -->
      <div>
        <h3 class="font-serif text-xl font-bold mb-6 text-bcc-gold">Connect</h3>
        <div class="flex space-x-4 mb-8">
          <a href="https://www.facebook.com/BastropCountyConservatives" target="_blank" rel="noopener noreferrer" class="bg-bcc-navy hover:bg-bcc-red p-2 rounded-full transition-colors" aria-label="Facebook">
            <Icon name="lucide:facebook" class="w-5 h-5" />
          </a>
          <a href="https://www.instagram.com/bastropcountyconservatives/" target="_blank" rel="noopener noreferrer" class="bg-bcc-navy hover:bg-bcc-red p-2 rounded-full transition-colors" aria-label="Instagram">
            <Icon name="lucide:instagram" class="w-5 h-5" />
          </a>
          <a href="https://www.youtube.com/bastropcountyconservatives" target="_blank" rel="noopener noreferrer" class="bg-bcc-navy hover:bg-bcc-red p-2 rounded-full transition-colors" aria-label="YouTube">
            <Icon name="lucide:youtube" class="w-5 h-5" />
          </a>
        </div>
        
        <div>
          <p class="font-bold mb-3">Stay Updated</p>
          <a href="/subscribe" class="inline-block bg-white text-bcc-navy hover:bg-bcc-gold px-4 py-2 rounded font-semibold transition-colors text-sm">
            Sign Up for Newsletter
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-bcc-gray-700 pt-8 flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-bcc-gray-400">
      <p>&copy; {new Date().getFullYear()} Bastrop County Conservatives. All rights reserved.</p>
      <div class="flex space-x-6">
        <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="/sitemap" class="hover:text-white transition-colors">Sitemap</a>
        <a href="/llm.txt" class="hover:text-white transition-colors">llm.txt</a>
      </div>
    </div>
  </div>
</footer>
