---
import { Icon } from 'astro-icon/components';

export interface Props {
  class?: string;
}

const { class: className = '' } = Astro.props;
---

<div class={`flex items-center justify-center py-12 w-full opacity-80 ${className}`} aria-hidden="true">
  <div class="h-px bg-gradient-to-r from-transparent to-bcc-navy w-1/4 md:w-1/3"></div>
  <Icon name="lucide:star" class="h-6 w-6 text-bcc-red mx-4 fill-current" />
  <div class="h-px bg-gradient-to-l from-transparent to-bcc-navy w-1/4 md:w-1/3"></div>
</div>
