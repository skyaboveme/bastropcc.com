---
export interface Props {
  title: string;
  subtitle?: string;
  centered?: boolean;
  class?: string;
}

const { title, subtitle, centered = false, class: className = '' } = Astro.props;
---

<div class:list={['mb-12', centered ? 'text-center' : '', className]}>
  <h2 class:list={[
    'font-serif text-3xl md:text-5xl font-bold text-bcc-navy mb-4',
    centered ? 'mx-auto' : ''
  ]}>
    {title}
  </h2>
  {subtitle && (
    <p class:list={[
      'text-lg md:text-xl text-bcc-gray-600 max-w-3xl',
      centered ? 'mx-auto' : ''
    ]}>
      {subtitle}
    </p>
  )}
</div>
