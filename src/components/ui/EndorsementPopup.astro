---
import { Icon } from 'astro-icon/components';
---

<div id="endorsement-popup" class="fixed inset-0 z-[100] flex items-center justify-center bg-bcc-navy/80 hidden opacity-0 transition-opacity duration-300 px-4 py-8">
  <div class="bg-slate-100 rounded-2xl shadow-2xl max-w-5xl w-full p-6 md:p-10 relative transform scale-95 transition-transform duration-300 max-h-[95vh] overflow-y-auto" id="endorsement-popup-content">
    <button id="close-endorsement-popup" class="absolute top-4 right-4 text-bcc-gray-400 hover:text-bcc-red transition-colors bg-white rounded-full p-2 shadow-sm" aria-label="Close popup">
      <Icon name="lucide:x" class="w-6 h-6" />
    </button>
    
    <div class="text-center mb-8">
      <p class="text-bcc-red font-bold uppercase tracking-widest text-sm md:text-base mb-2">Congratulations</p>
      <h2 class="text-3xl md:text-4xl font-serif font-bold text-bcc-navy uppercase tracking-wide">To Our Election Winners!</h2>
      <p class="text-bcc-gray-600 mt-3 font-medium max-w-2xl mx-auto">Congratulations to Wini Griffin, Daña Tovar, and Ishmael Harris on winning their election. Thank you for stepping up to serve Bastrop County.</p>
    </div>
    
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      
      <!-- Winner 1 -->
      <div class="bg-white rounded-xl shadow-md overflow-hidden flex flex-col border border-gray-100 group">
        <div class="bg-[#b91c1c] text-white text-center py-2 text-xs font-bold uppercase tracking-wider">Election Winner</div>
        <div class="px-6 py-8 flex flex-col items-center text-center flex-grow">
          <h3 class="text-2xl font-bold text-[#1e293b] uppercase mb-2 group-hover:text-[#b91c1c] transition-colors">Wini Griffin</h3>
          <p class="text-gray-500 font-medium mb-8">Smithville City Council<br/>Place 4</p>
          <a href="https://voteforwini.com" target="_blank" rel="noopener noreferrer" class="mt-auto w-full bg-[#1e293b] text-white font-bold py-3 rounded-md hover:bg-[#b91c1c] shadow-sm transition-colors text-sm">Visit Website</a>
        </div>
      </div>
      
      <!-- Winner 2 -->
      <div class="bg-white rounded-xl shadow-md overflow-hidden flex flex-col border border-gray-100 group">
        <div class="bg-[#b91c1c] text-white text-center py-2 text-xs font-bold uppercase tracking-wider">Election Winner</div>
        <div class="px-6 py-8 flex flex-col items-center text-center flex-grow">
          <h3 class="text-2xl font-bold text-[#1e293b] uppercase mb-2 group-hover:text-[#b91c1c] transition-colors">Daña Tovar</h3>
          <p class="text-gray-500 font-medium mb-8">Smithville City Council<br/>Place 5</p>
          <a href="https://electdanatovar.com" target="_blank" rel="noopener noreferrer" class="mt-auto w-full bg-[#1e293b] text-white font-bold py-3 rounded-md hover:bg-[#b91c1c] shadow-sm transition-colors text-sm">Visit Website</a>
        </div>
      </div>
      
      <!-- Winner 3 -->
      <div class="bg-white rounded-xl shadow-md overflow-hidden flex flex-col border border-gray-100 group">
        <div class="bg-[#b91c1c] text-white text-center py-2 text-xs font-bold uppercase tracking-wider">Election Winner</div>
        <div class="px-6 py-8 flex flex-col items-center text-center flex-grow">
          <h3 class="text-2xl font-bold text-[#1e293b] uppercase mb-2 group-hover:text-[#b91c1c] transition-colors">Ishmael Harris</h3>
          <p class="text-gray-500 font-medium mb-8">Bastrop Mayor</p>
          <a href="https://www.ishmaelharrisformayor.com" target="_blank" rel="noopener noreferrer" class="mt-auto w-full bg-[#1e293b] text-white font-bold py-3 rounded-md hover:bg-[#b91c1c] shadow-sm transition-colors text-sm">Visit Website</a>
        </div>
      </div>
      
    </div>
    
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const popup = document.getElementById('endorsement-popup');
    const popupContent = document.getElementById('endorsement-popup-content');
    const closeBtn = document.getElementById('close-endorsement-popup');
    
    if (!popup || !closeBtn || !popupContent) return;
    
    // Ensure popup displays once per user by using sessionStorage (once per visit)
    // Or localStorage if you want it once ever. Let's use sessionStorage so it only shows once per browser session.
    const hasSeenPopup = sessionStorage.getItem('hasSeenWinnersPopup2026');
    
    if (!hasSeenPopup) {
      // 1 second delay allows the page to settle before asking for attention
      setTimeout(() => {
        popup.classList.remove('hidden');
        // Force reflow for transitions
        void popup.offsetWidth;
        popup.classList.remove('opacity-0');
        popupContent.classList.remove('scale-95');
      }, 1000);
      
      const closePopup = () => {
        popup.classList.add('opacity-0');
        popupContent.classList.add('scale-95');
        setTimeout(() => {
          popup.classList.add('hidden');
        }, 300);
        sessionStorage.setItem('hasSeenWinnersPopup2026', 'true');
      };
      
      closeBtn.addEventListener('click', closePopup);
      
      // Close when clicking the semi-transparent background overlay
      popup.addEventListener('click', (e) => {
        if (e.target === popup) {
          closePopup();
        }
      });
      
      // Close on escape key press
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && !popup.classList.contains('hidden')) {
          closePopup();
        }
      });
    }
  });
</script>
