---
import { Icon } from 'astro-icon/components';

export interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon = 'lucide:star' } = Astro.props;
---

<div class="bg-white p-8 rounded-xl shadow-sm border-l-4 border-bcc-red hover:shadow-md transition-shadow h-full">
  <div class="bg-bcc-cream w-14 h-14 rounded-full flex items-center justify-center mb-6">
    <Icon name={icon} class="w-7 h-7 text-bcc-navy" />
  </div>
  <h3 class="font-serif text-xl font-bold text-bcc-navy mb-3">{title}</h3>
  <p class="text-bcc-gray-600">
    {description}
  </p>
</div>
