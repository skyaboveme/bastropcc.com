---
import PageLayout from '../layouts/PageLayout.astro';
import Button from '../components/ui/Button.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import { Icon } from 'astro-icon/components';
---

<PageLayout 
  title="Donate to Bastrop County Conservatives PAC"
  heading="Fuel the Fight for Bastrop County"
  subheading="Your financial support directly powers our ability to elect conservative leaders who will protect our 250+ years of tradition."
>

  <div class="max-w-3xl mx-auto mb-16 not-prose">
    <div class="bg-white p-8 md:p-12 rounded-2xl shadow-xl border-t-8 border-bcc-red text-center">
      <h3 class="text-2xl font-serif font-bold text-bcc-navy mb-4">Select Your Impact</h3>
      <p class="text-bcc-gray-600 mb-8 max-w-lg mx-auto">
        Every dollar raised stays right here in Bastrop County, funding signs, mailers, events, and ground-game operations for verified conservative candidates.
      </p>
      
      <!-- DonorBox Widget -->
      <div class="mt-8 mb-4 min-h-[500px] flex justify-center">
        <script src="https://donorbox.org/widget.js" data-paypalExpress="false"></script>
        <iframe 
          src="https://donorbox.org/embed/donation-form-155?a=b" 
          name="donorbox" 
          frameborder="0" 
          scrolling="no" 
          height="900px" 
          width="100%" 
          style="max-width: 500px; min-width: 250px; max-height:none!important"
          title="Donate to Bastrop County Conservatives"
        ></iframe>
      </div>
      
      <div class="mt-8 pt-6 border-t border-bcc-gray-100 flex items-center justify-center gap-2 text-bcc-gray-500 text-sm">
        <Icon name="lucide:lock" class="w-4 h-4" />
        <span>Secure donation processing via DonorBox</span>
      </div>
    </div>
  </div>

  <!-- Transparency Section (Reused Content) -->
  <div class="my-16 border-t border-bcc-gray-200 pt-16 max-w-3xl mx-auto pb-10">
    <SectionHeading title="Use of Funds" class="mb-8" />
    <p class="text-lg text-bcc-gray-700 leading-relaxed mb-6">
      As a Political Action Committee, 100% of our funds are dedicated to advancing conservative causes in Bastrop County. Your donations power:
    </p>
    <ul class="space-y-4 my-8 list-none pl-0">
      <li class="flex items-start">
        <div class="bg-bcc-cream p-1 rounded mt-1 mr-4 text-bcc-gold shrink-0">
          <Icon name="lucide:check" class="w-5 h-5" />
        </div>
        <span class="text-bcc-gray-700"><strong>Direct Support:</strong> Endorsements and financial backing for verified conservative candidates in local races.</span>
      </li>
      <li class="flex items-start">
        <div class="bg-bcc-cream p-1 rounded mt-1 mr-4 text-bcc-gold shrink-0">
          <Icon name="lucide:check" class="w-5 h-5" />
        </div>
        <span class="text-bcc-gray-700"><strong>Voter Education:</strong> Publishing and distributing voter guides reaching thousands of Bastrop County residents.</span>
      </li>
      <li class="flex items-start">
        <div class="bg-bcc-cream p-1 rounded mt-1 mr-4 text-bcc-gold shrink-0">
          <Icon name="lucide:check" class="w-5 h-5" />
        </div>
        <span class="text-bcc-gray-700"><strong>Strategic Marketing:</strong> Direct mail, signs, and digital campaigns to counter progressive influence in our community.</span>
      </li>
      <li class="flex items-start">
        <div class="bg-bcc-cream p-1 rounded mt-1 mr-4 text-bcc-gold shrink-0">
          <Icon name="lucide:check" class="w-5 h-5" />
        </div>
        <span class="text-bcc-gray-700"><strong>Community Mobilization:</strong> Monthly events to organize the conservative grassroots and build a cohesive voting block.</span>
      </li>
    </ul>

    <div class="bg-bcc-gray-50 border border-bcc-gray-200 rounded p-4 text-center mt-12">
      <p class="text-xs uppercase tracking-wider font-semibold text-bcc-gray-600">
        Political Advertising Paid For By Bastrop County Conservatives PAC
      </p>
    </div>
  </div>

</PageLayout>
