---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import { Icon } from 'astro-icon/components';

const resources = [
  {
    title: "Bastrop County Elections Website",
    desc: "The official hub for all county election records and information.",
    url: "https://bastropvotes.org",
    icon: "lucide:globe"
  },
  {
    title: "Voting Locations, Dates & Times",
    desc: "Find where and when you can cast your ballot during early voting and on Election Day.",
    url: "https://bastropvotes.org/voting-schedule",
    icon: "lucide:calendar-clock"
  },
  {
    title: "Sample Ballot / Voter Lookup",
    desc: "View your specific sample ballot before heading to the polls.",
    url: "https://bastropvotes.org/voter-lookup",
    icon: "lucide:file-text"
  },
  {
    title: "Who Represents Me?",
    desc: "Look up your current elected officials at the local, state, and federal levels.",
    url: "https://bastropvotes.org/voter-lookup#ElectedOfficials",
    icon: "lucide:users"
  },
  {
    title: "Register to Vote",
    desc: "Not registered? Recently moved? Get the information you need to register today.",
    url: "https://bastropvotes.org/voter-registration-information",
    icon: "lucide:check-square"
  },
  {
    title: "Become an Election Worker",
    desc: "Ensure election integrity firsthand by working at a Bastrop County polling location.",
    url: "https://bastropvotes.org/poll-worker-information",
    icon: "lucide:briefcase"
  },
  {
    title: "Become a Poll Watcher",
    desc: "Learn the requirements and process to become an official poll watcher.",
    url: "https://bastropvotes.org/poll-watchers",
    icon: "lucide:eye"
  }
];
---

<PageLayout 
  title="Bastrop County Voter Information & Resources"
  heading="Voter Information"
  subheading="Everything you need to confidently participate in Bastrop County elections."
>
  
  <div class="mb-12">
    <p class="text-xl text-bcc-navy font-medium leading-relaxed">
      A well-informed and active electorate is the foundation of a free republic. We've compiled the essential resources you need to register, research, and cast your ballot effectively in Bastrop County.
    </p>
  </div>

  <div class="not-prose max-w-5xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
      {resources.map((res) => (
        <a href={res.url} target="_blank" rel="noopener noreferrer" class="group flex flex-col bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md hover:border-bcc-gold transition-all duration-300 transform hover:-translate-y-1">
          <div class="flex items-start gap-4 mb-4 flex-grow">
            <div class="bg-bcc-cream p-3 rounded-lg text-bcc-navy group-hover:bg-bcc-gold group-hover:text-bcc-navy transition-colors shrink-0">
              <Icon name={res.icon} class="w-6 h-6" />
            </div>
            <div>
              <h3 class="font-serif text-xl font-bold text-bcc-navy mb-1 group-hover:text-bcc-red transition-colors">{res.title}</h3>
              <p class="text-sm text-bcc-gray-600 line-clamp-2">{res.desc}</p>
            </div>
          </div>
          <div class="mt-auto pt-4 border-t border-bcc-gray-100 flex items-center text-sm font-bold text-bcc-navy group-hover:text-bcc-red transition-colors">
            Access Resource <Icon name="lucide:arrow-right" class="w-4 h-4 ml-1 transform group-hover:translate-x-1 transition-transform" />
          </div>
        </a>
      ))}
    </div>
  </div>

  <div class="mt-20 p-8 bg-bcc-navy text-white rounded-xl text-center not-prose shadow-lg">
    <Icon name="lucide:alert-circle" class="w-12 h-12 text-bcc-gold mx-auto mb-4" />
    <h3 class="text-2xl font-serif font-bold mb-3">Election Integrity Starts With You</h3>
    <p class="max-w-xl mx-auto text-bcc-cream mb-6">
      If you witness any irregularities or have questions regarding the voting process, we strongly encourage you to serve as an Election Worker or Poll Watcher. Step up and secure the vote.
    </p>
  </div>

</PageLayout>
