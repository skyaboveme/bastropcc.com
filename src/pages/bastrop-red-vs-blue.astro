  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      // General tabs script
      const setupTabs = (groupName) => {
        const buttons = document.querySelectorAll(`[data-tab-group="${groupName}"]`);
        const panes = document.querySelectorAll(`[data-pane-group="${groupName}"]`);
        
        buttons.forEach(btn => {
          btn.addEventListener('click', () => {
            const targetId = btn.getAttribute('data-tab-target');
            
            // Reset all buttons in this group
            buttons.forEach(b => {
               b.classList.remove('bg-bcc-navy', 'text-white', 'border-bcc-navy');
               b.classList.add('bg-white', 'text-gray-600', 'border-gray-200');
               if (groupName === 'main' && b.classList.contains('text-bcc-gray-600')) {
                 b.classList.remove('text-bcc-gray-600', 'border-bcc-gray-200');
               }
            });
            
            // Set active button
            btn.classList.add('bg-bcc-navy', 'text-white', 'border-bcc-navy');
            btn.classList.remove('bg-white', 'text-gray-600', 'border-gray-200', 'text-bcc-gray-600', 'border-bcc-gray-200');
            
            // Hide all panes
            panes.forEach(p => p.classList.add('hidden'));
            
            // Show target pane
            const target = document.getElementById(targetId);
            if(target) target.classList.remove('hidden');
          });
        });
      };
      
      const uniqueGroups = [...new Set(Array.from(document.querySelectorAll('[data-tab-group]')).map(el => el.getAttribute('data-tab-group')))];
      uniqueGroups.forEach(setupTabs);

      // Card toggle implementation
      const toggleButtons = document.querySelectorAll('.toggle-card-btn');
      toggleButtons.forEach(btn => {
        btn.addEventListener('click', (e) => {
          const detailDiv = e.target.nextElementSibling;
          if (detailDiv.classList.contains('hidden')) {
            detailDiv.classList.remove('hidden');
            e.target.textContent = 'Toggle Less Intel';
          } else {
            detailDiv.classList.add('hidden');
            e.target.textContent = 'Toggle Full Intel';
          }
        });
      });
    });
  </script>

