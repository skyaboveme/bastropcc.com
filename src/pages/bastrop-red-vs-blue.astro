---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import { Icon } from 'astro-icon/components';

// ── DATA ──────────────────────────────────────────────────────────

const klausData = {
  name: "Gregory Klaus",
  party: "R",
  role: "Incumbent Bastrop County Judge",
  status: "GOP NOMINEE — Primary Won 63.8%",
  pct: 63.8,
  votes: "~5,600",
  viability: 74,
  bio: "75-year-old Navy veteran who served in Vietnam. Former owner of an air conditioning and heating business. Lifelong Bastrop County resident who chairs the Commissioners Court. Previously defeated Loucks (2022 runoff) and Jackson (2022 general). Running on a record of managed growth and fiscal responsibility.",
  platform: ["Fiscal responsibility & balanced budgets", "Responsible growth management", "Public safety & law enforcement support", "Infrastructure & roads for a growing county"],
  strengths: ["Incumbent with proven track record — won in 2022", "Dominant primary win 63.8% — clear party consolidation", "Vietnam vet with deep community identity", "Growth management record resonates with longtime residents"],
  risks: ["Bastrop growing rapidly — new residents may not have existing loyalty", "Jackson has 30+ years of community presence and name recognition", "Fast growth brings more Democratic-leaning Austin transplants"],
  endorsements: [],
};

const jacksonData = {
  name: "Dock Jackson",
  party: "D",
  role: "Former Bastrop City Council (30 yrs) / Former County Staffer",
  status: "DEM NOMINEE — Ran Unopposed",
  pct: null,
  votes: "Dem Primary: Unopposed",
  viability: 36,
  bio: "5th-generation Bastropian with nearly three decades on the Bastrop City Council. Holds the Certified Municipal Official designation from the Texas Municipal League. Retired from Bastrop County after ~10 years of combined service in the County Judge's office and Clerk/JP offices. Founded the county-wide Juneteenth Committee 30+ years ago. Previously lost to Klaus in the 2022 general.",
  platform: ["Deep community investment & county services", "Experienced budget and government management", "Public safety & first responder support", "Growth planning with community input"],
  strengths: ["5th-generation Bastropian — authentic deep roots", "30 years on City Council — massive name recognition", "Former county staffer in the Judge's own office", "Lost narrowly to Klaus in 2022 — rematch with experience"],
  risks: ["Lost to Klaus in 2022 general election", "Bastrop County is strongly Republican in partisan elections", "No statewide or national coattails in a GOP-dominated cycle"],
  endorsements: [],
};

const presidentialData = [
  { year: "2000", r: 56.3, d: 38.1, rVotes: "10,310", dVotes: "6,973",   total: "18,307", winner: "Bush" },
  { year: "2004", r: 56.7, d: 41.8, rVotes: "13,290", dVotes: "9,794",   total: "23,441", winner: "Bush" },
  { year: "2008", r: 53.5, d: 45.3, rVotes: "13,797", dVotes: "11,678",  total: "25,793", winner: "McCain" },
  { year: "2012", r: 57.3, d: 40.3, rVotes: "14,019", dVotes: "9,860",   total: "24,457", winner: "Romney" },
  { year: "2016", r: 57.8, d: 37.4, rVotes: "16,314", dVotes: "10,555",  total: "28,250", winner: "Trump" },
  { year: "2020", r: 56.0, d: 42.2, rVotes: "~19,900", dVotes: "~15,000", total: "~35,500", winner: "Trump" },
  { year: "2024", r: 58.6, d: 40.1, rVotes: "23,276", dVotes: "15,941",  total: "39,956",  winner: "Trump" },
];

const popData = [
  { year: "2010", pop: 74381 },
  { year: "2015", pop: 82600 },
  { year: "2019", pop: 84522 },
  { year: "2020", pop: 97216 },
  { year: "2022", pop: 105000 },
  { year: "2023", pop: 111200 },
  { year: "2024", pop: 114931 },
  { year: "2026*", pop: 122531 },
];

const subTabsData = [
  { id: "race", label: "2026 RACE" },
  { id: "growth", label: "GROWTH" },
  { id: "partisan", label: "PARTISAN TRENDS" },
  { id: "voter-data", label: "VOTER DATA" },
  { id: "social", label: "SOCIAL MEDIA" },
  { id: "intel", label: "LOCAL INTEL" }
];

const downBallotRaces = [
  {
    office: "Bastrop County District Clerk",
    election: "Republican Primary (March 3, 2026)",
    status: "R Primary",
    candidates: [
      { name: "Tamara Batot", party: "R" },
      { name: "Holly Cox", party: "R" },
      { name: "Sarah Loucks", party: "R" },
      { name: "Ward Northcutt", party: "R" }
    ]
  },
  {
    office: "City of Bastrop Mayor",
    election: "General Election (May 2, 2026)",
    status: "Non-Partisan",
    candidates: [
      { name: "Ishmael Harris", party: "Incumbent" },
      { name: "Joseph Stanfield", party: "Challenger" }
    ]
  },
  {
    office: "City of Bastrop Council, Pos. 3",
    election: "General Election (May 2, 2026)",
    status: "Non-Partisan",
    candidates: [
      { name: "Kevin Plunkett", party: "Unopposed" }
    ]
  }
];
---

<PageLayout 
  title="Bastrop Red vs Blue"
  heading="Bastrop Red vs Blue"
  subheading="Electoral Intelligence and Demographic Shifts in Bastrop County."
>

  <div class="mb-20 not-prose max-w-5xl mx-auto">
    
    <!-- Top Level Tabs -->
    <div class="flex flex-wrap gap-2 mb-8 border-b border-bcc-gray-200 pb-4">
      {subTabsData.map((tab, idx) => (
        <button 
          data-tab-group="main" 
          data-tab-target={`pane-${tab.id}`} 
          class={`px-4 py-2 font-bold text-sm rounded-md border transition-colors ${idx === 0 ? 'bg-bcc-navy text-white border-bcc-navy' : 'bg-white text-bcc-gray-600 border-bcc-gray-200 hover:border-bcc-navy hover:text-bcc-navy'}`}
        >
          {tab.label}
        </button>
      ))}
    </div>

    <!-- PANE 1: RACE -->
    <div id="pane-race" data-pane-group="main" class="block">
      <div class="bg-bcc-gray-50 border border-bcc-gray-200 rounded-xl p-6 mb-8">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
          <div class="bg-white border border-bcc-gray-200 rounded-lg p-4 text-center">
            <div class="text-blue-600 font-bold text-2xl">Nov 3, 2026</div>
            <div class="text-bcc-gray-600 text-xs font-mono mt-1">GENERAL ELECTION</div>
          </div>
          <div class="bg-white border border-bcc-gray-200 rounded-lg p-4 text-center">
            <div class="text-bcc-red font-bold text-2xl">63.8%</div>
            <div class="text-bcc-gray-600 text-xs font-mono mt-1">Klaus primary win</div>
          </div>
          <div class="bg-white border border-bcc-gray-200 rounded-lg p-4 text-center">
            <div class="text-yellow-600 font-bold text-2xl">REMATCH</div>
            <div class="text-bcc-gray-600 text-xs font-mono mt-1">Same matchup as 2022</div>
          </div>
        </div>
        <p class="text-bcc-gray-700 text-sm leading-relaxed">
          Gregory Klaus won the Republican primary outright on March 3, 2026 with 63.8% — no runoff needed. He faces Democrat Dock Jackson in the November 3 general election, a rematch of their 2022 contest. Jackson ran unopposed in the Democratic primary, preserving his resources for the general.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
        <!-- Klaus Card -->
        <div class="border-2 border-bcc-red rounded-xl bg-white overflow-hidden shadow-sm">
          <div class="p-6">
            <div class="inline-block bg-red-50 text-bcc-red font-mono text-xs font-bold tracking-wider px-3 py-1 rounded border border-red-200 mb-4">
              {klausData.status}
            </div>
            <div class="flex justify-between items-start gap-4 mb-4">
              <div>
                <div class="text-gray-900 font-bold text-2xl">{klausData.name}</div>
                <div class="text-gray-500 text-sm mt-1">{klausData.role}</div>
              </div>
              <div class="text-right shrink-0">
                <div class="text-bcc-red font-bold text-3xl leading-none">{klausData.pct}%</div>
                <div class="text-gray-500 font-mono text-xs mt-1">{klausData.votes}</div>
              </div>
            </div>

            <!-- Viability -->
            <div class="bg-bcc-gray-50 border border-bcc-gray-200 rounded-lg p-4 mb-6">
              <div class="flex justify-between mb-2">
                <span class="font-mono text-xs text-gray-500 tracking-wider">VIABILITY</span>
                <span class="font-mono text-xs font-bold text-green-600">{klausData.viability}/100</span>
              </div>
              <div class="bg-gray-200 rounded-full h-2 overflow-hidden">
                <div class="bg-green-500 h-full rounded-full" style={`width: ${klausData.viability}%`}></div>
              </div>
            </div>

            <p class="text-gray-700 text-sm leading-relaxed mb-6">{klausData.bio}</p>

            <button class="toggle-card-btn text-bcc-red border border-bcc-red font-mono text-xs font-bold tracking-wider px-4 py-2 rounded uppercase w-full">
              Toggle Full Intel
            </button>
            <div class="card-details hidden mt-6 pt-6 border-t border-gray-100">
              <div class="mb-6">
                <div class="text-yellow-600 font-mono text-xs font-bold tracking-wider mb-3">PLATFORM</div>
                {klausData.platform.map(p => (
                  <div class="flex gap-2 mb-2">
                    <span class="text-bcc-red shrink-0">▸</span>
                    <span class="text-gray-700 text-sm">{p}</span>
                  </div>
                ))}
              </div>
              <div class="grid grid-cols-1 gap-6">
                <div>
                  <div class="text-green-600 font-mono text-xs font-bold tracking-wider mb-3">STRENGTHS</div>
                  {klausData.strengths.map(s => (
                    <div class="flex gap-2 mb-2">
                      <span class="text-green-600 shrink-0">+</span>
                      <span class="text-gray-700 text-sm">{s}</span>
                    </div>
                  ))}
                </div>
                <div>
                  <div class="text-red-500 font-mono text-xs font-bold tracking-wider mb-3">RISKS</div>
                  {klausData.risks.map(r => (
                    <div class="flex gap-2 mb-2">
                      <span class="text-red-500 shrink-0">−</span>
                      <span class="text-gray-700 text-sm">{r}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Jackson Card -->
        <div class="border-2 border-blue-500 rounded-xl bg-white overflow-hidden shadow-sm">
          <div class="p-6">
            <div class="inline-block bg-blue-50 text-blue-600 font-mono text-xs font-bold tracking-wider px-3 py-1 rounded border border-blue-200 mb-4">
              {jacksonData.status}
            </div>
            <div class="flex justify-between items-start gap-4 mb-4">
              <div>
                <div class="text-gray-900 font-bold text-2xl">{jacksonData.name}</div>
                <div class="text-gray-500 text-sm mt-1">{jacksonData.role}</div>
              </div>
              <div class="shrink-0 bg-blue-50 text-blue-600 font-mono text-xs font-bold px-3 py-2 rounded border border-blue-200">
                {jacksonData.votes}
              </div>
            </div>

            <!-- Viability -->
            <div class="bg-bcc-gray-50 border border-bcc-gray-200 rounded-lg p-4 mb-6">
              <div class="flex justify-between mb-2">
                <span class="font-mono text-xs text-gray-500 tracking-wider">VIABILITY</span>
                <span class="font-mono text-xs font-bold text-yellow-600">{jacksonData.viability}/100</span>
              </div>
              <div class="bg-gray-200 rounded-full h-2 overflow-hidden">
                <div class="bg-yellow-500 h-full rounded-full" style={`width: ${jacksonData.viability}%`}></div>
              </div>
            </div>

            <p class="text-gray-700 text-sm leading-relaxed mb-6">{jacksonData.bio}</p>

            <button class="toggle-card-btn text-blue-600 border border-blue-500 font-mono text-xs font-bold tracking-wider px-4 py-2 rounded uppercase w-full">
              Toggle Full Intel
            </button>
            <div class="card-details hidden mt-6 pt-6 border-t border-gray-100">
              <div class="mb-6">
                <div class="text-yellow-600 font-mono text-xs font-bold tracking-wider mb-3">PLATFORM</div>
                {jacksonData.platform.map(p => (
                  <div class="flex gap-2 mb-2">
                    <span class="text-blue-500 shrink-0">▸</span>
                    <span class="text-gray-700 text-sm">{p}</span>
                  </div>
                ))}
              </div>
              <div class="grid grid-cols-1 gap-6">
                <div>
                  <div class="text-green-600 font-mono text-xs font-bold tracking-wider mb-3">STRENGTHS</div>
                  {jacksonData.strengths.map(s => (
                    <div class="flex gap-2 mb-2">
                      <span class="text-green-600 shrink-0">+</span>
                      <span class="text-gray-700 text-sm">{s}</span>
                    </div>
                  ))}
                </div>
                <div>
                  <div class="text-red-500 font-mono text-xs font-bold tracking-wider mb-3">RISKS</div>
                  {jacksonData.risks.map(r => (
                    <div class="flex gap-2 mb-2">
                      <span class="text-red-500 shrink-0">−</span>
                      <span class="text-gray-700 text-sm">{r}</span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="bg-bcc-gray-50 border border-bcc-gray-200 rounded-xl p-6 mb-8">
        <div class="text-center mb-4">
          <span class="text-bcc-red font-bold text-lg">Gregory Klaus</span>
          <span class="text-gray-500 font-mono text-sm font-bold tracking-widest mx-4">VS — NOV 3</span>
          <span class="text-blue-600 font-bold text-lg">Dock Jackson</span>
        </div>
        <p class="text-gray-600 text-sm leading-relaxed text-center max-w-2xl mx-auto">
          Klaus beat Jackson in November 2022. Bastrop is growing fast — ~3,100 net domestic in-migrants per year, primarily from Travis County (Austin). The GOP structural advantage holds for 2026, but the demographic trend favors Democrats long-term.
        </p>
      </div>

      <!-- Other 2026 Races -->
      <h3 class="font-serif text-2xl font-bold text-bcc-navy mb-6 border-b border-bcc-gray-200 pb-2">Other 2026 Local Races</h3>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
        {downBallotRaces.map(race => (
          <div class="bg-white border border-bcc-gray-200 rounded-xl overflow-hidden shadow-sm">
            <div class="bg-bcc-gray-50 px-5 py-3 border-b border-bcc-gray-200 flex justify-between items-center">
               <span class="font-serif font-bold text-bcc-navy">{race.office}</span>
               <span class="text-xs font-mono font-bold tracking-wider text-bcc-red bg-red-50 border border-red-100 px-2 py-1 rounded">{race.status}</span>
            </div>
            <div class="p-5">
              <div class="text-xs text-gray-500 font-mono mb-4">{race.election}</div>
              <ul class="space-y-3">
                {race.candidates.map(c => (
                  <li class="flex justify-between items-center text-sm">
                    <span class="font-medium text-gray-800">{c.name}</span>
                    <span class={`text-xs font-mono font-bold ${c.party === 'R' ? 'text-bcc-red' : 'text-gray-500'}`}>{c.party}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>


    <!-- PANE 2: GROWTH -->
    <div id="pane-growth" data-pane-group="main" class="hidden">
      <!-- Header stats -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
        <div class="bg-white border border-bcc-gray-200 rounded-lg p-4 text-center shadow-sm">
          <div class="text-blue-500 font-bold text-xl leading-none">~122,531</div>
          <div class="text-gray-500 text-xs mt-2 font-mono">2026 est. population</div>
        </div>
        <div class="bg-white border border-bcc-gray-200 rounded-lg p-4 text-center shadow-sm">
          <div class="text-green-600 font-bold text-xl leading-none">+64.7%</div>
          <div class="text-gray-500 text-xs mt-2 font-mono">Growth since 2010</div>
        </div>
        <div class="bg-white border border-bcc-gray-200 rounded-lg p-4 text-center shadow-sm">
          <div class="text-yellow-600 font-bold text-xl leading-none">3,100+</div>
          <div class="text-gray-500 text-xs mt-2 font-mono">Net domestic arrivals/yr</div>
        </div>
        <div class="bg-white border border-bcc-gray-200 rounded-lg p-4 text-center shadow-sm">
          <div class="text-orange-500 font-bold text-xl leading-none">37.5 yrs</div>
          <div class="text-gray-500 text-xs mt-2 font-mono">Median age (dropping)</div>
        </div>
      </div>
      
      <div class="flex flex-wrap gap-2 mb-8">
        {["population|POPULATION", "migration|MIGRATION", "demographics|DEMOGRAPHICS", "electoral|ELECTORAL RISK", "employers|WHO'S MOVING IN"].map((spec, idx) => {
          const [id, label] = spec.split("|");
          return (
            <button 
              data-tab-group="growth" 
              data-tab-target={`growth-${id}`} 
              class={`px-3 py-1.5 font-bold text-xs font-mono tracking-wider rounded border transition-colors ${idx === 0 ? 'bg-bcc-navy text-white border-bcc-navy' : 'bg-white text-gray-600 border-gray-200 hover:border-bcc-navy hover:text-bcc-navy'}`}
            >
              {label}
            </button>
          );
        })}
      </div>

      <div id="growth-population" data-pane-group="growth" class="block">
        <div class="text-bcc-navy font-mono text-xs font-bold tracking-widest mb-4">POPULATION GROWTH — BASTROP COUNTY</div>
        <div class="flex flex-col gap-3 mb-8">
          {popData.map((d, i) => (
            <div class="flex items-center gap-4">
              <div class="w-12 text-gray-500 font-mono text-xs text-right shrink-0">{d.year}</div>
              <div class="flex-1 bg-gray-100 rounded h-8 relative overflow-hidden">
                <div class={`h-full rounded ${d.year === '2026*' ? 'bg-blue-300' : 'bg-bcc-navy'}`} style={`width: ${(d.pop / 130000) * 100}%; opacity: ${0.5 + (i * 0.05)}`}></div>
                <div class="absolute left-3 top-1/2 -translate-y-1/2 text-white font-bold text-sm drop-shadow-md">{d.pop.toLocaleString()}</div>
              </div>
              {i > 0 ? (
                <div class="w-14 text-green-600 font-mono text-xs font-bold shrink-0">+{(((d.pop - popData[i-1].pop) / popData[i-1].pop) * 100).toFixed(1)}%</div>
              ) : (
                <div class="w-14"></div>
              )}
            </div>
          ))}
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="bg-white border border-gray-200 rounded-lg p-5 shadow-sm">
            <div class="text-yellow-600 font-mono text-xs font-bold tracking-wider mb-2">13TH FASTEST-GROWING COUNTY IN TEXAS</div>
            <div class="text-gray-700 text-sm leading-relaxed">Population grew <strong class="text-green-600">13.9%</strong> between 2020 and 2023 alone — one of the fastest clips in the state.</div>
          </div>
          <div class="bg-white border border-gray-200 rounded-lg p-5 shadow-sm">
            <div class="text-yellow-600 font-mono text-xs font-bold tracking-wider mb-2">CITY OF BASTROP: 20K BY 2029</div>
            <div class="text-gray-700 text-sm leading-relaxed">City Manager projects <strong class="text-orange-500">20,000 residents by 2029</strong> — a 42% surge in just 4 years from current levels.</div>
          </div>
        </div>
      </div>

      <div id="growth-migration" data-pane-group="growth" class="hidden">
        <div class="text-bcc-navy font-mono text-xs font-bold tracking-widest mb-2">WHERE NEW RESIDENTS ARE COMING FROM</div>
        <div class="text-gray-500 text-sm mb-6">Census PEP shows ~3,100 net domestic + ~242 international arrivals annually. Origin mix estimated from IRS migration data and Austin MSA commuter analysis.</div>
        
        <div class="flex flex-col gap-5 mb-8">
          {[
            { label: "Travis County (Austin)", pct: 38, color: "bg-bcc-red", text: "text-bcc-red", note: "Largest single source — Austin overflow" },
            { label: "Other TX Counties",      pct: 27, color: "bg-yellow-500", text: "text-yellow-600", note: "Williamson, Hays, Caldwell spillover" },
            { label: "Other US States",        pct: 22, color: "bg-blue-500", text: "text-blue-600", note: "CA, WA, NY transplants via Austin" },
            { label: "Natural Increase",       pct: 9,  color: "bg-green-500", text: "text-green-600", note: "442 net births over deaths (2023-24)" },
            { label: "International",          pct: 4,  color: "bg-purple-500", text: "text-purple-600", note: "~242 net international arrivals" },
          ].map((s) => (
            <div>
              <div class="flex justify-between mb-2 border-b border-gray-100 pb-1">
                <span class="text-gray-800 font-bold text-sm">{s.label}</span>
                <span class={`${s.text} font-mono font-bold text-sm`}>{s.pct}%</span>
              </div>
              <div class="bg-gray-100 rounded h-2.5 overflow-hidden">
                <div class={`${s.color} h-full rounded`} style={`width: ${s.pct}%`}></div>
              </div>
              <div class="text-gray-500 text-xs mt-1.5">{s.note}</div>
            </div>
          ))}
        </div>
        
        <div class="bg-orange-50 border border-orange-200 rounded-lg p-5">
          <div class="text-orange-600 font-mono text-xs font-bold tracking-wider mb-2">⚠ STRATEGIC CAUTION FOR REPUBLICAN CAMPAIGNS</div>
          <div class="text-orange-900 text-sm leading-relaxed">The single largest source of new Bastrop County residents is <strong>Travis County (Austin)</strong>. These households moved for affordability and space — not to change their politics. The "Austinization" of Bastrop is real: ex-Austinites bring blue-leaning registration patterns, progressive school board views, and reduced tolerance for anti-growth candidates.</div>
        </div>
      </div>

      <!-- Add placeholders for other Growth subtabs as needed, keep it concise -->
      <div id="growth-demographics" data-pane-group="growth" class="hidden">
        <div class="text-bcc-navy font-mono text-xs font-bold tracking-widest mb-4">BASTROP COUNTY DEMOGRAPHICS</div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-8">
          {[
            { label: "White (non-Hispanic)", pct: 45.7, color: "bg-gray-600" },
            { label: "Hispanic / Latino", pct: 44.0, color: "bg-orange-500" },
            { label: "Black / African American", pct: 5.7, color: "bg-blue-500" },
            { label: "Other / Multiracial", pct: 4.6, color: "bg-gray-400" },
          ].map(d => (
            <div class="bg-white border border-gray-200 rounded-lg p-5 shadow-sm">
              <div class="flex justify-between mb-3">
                <span class="text-gray-800 font-bold">{d.label}</span>
                <span class="font-mono font-bold text-lg">{d.pct}%</span>
              </div>
              <div class="bg-gray-100 rounded h-2 overflow-hidden">
                <div class={`${d.color} h-full rounded`} style={`width: ${d.pct}%`}></div>
              </div>
            </div>
          ))}
        </div>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          {[
            { label: "Median HH Income", val: "$82,730", sub: "Up from ~$72K in 2019", color: "text-green-600" },
            { label: "Median Age", val: "37.5 yrs", sub: "Down from 38.4 — getting younger", color: "text-yellow-600" },
            { label: "Bachelor's Degree+", val: "25.5%", sub: "Up as tech workers arrive", color: "text-blue-600" },
            { label: "Registered Voters", val: "62,294", sub: "As of March 2026 primary", color: "text-orange-500" },
