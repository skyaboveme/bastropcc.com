---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout
  title="Machine-Friendly Hub — Bastrop County Conservatives"
  description="Machine-friendly hub page for Bastrop County Conservatives (BCC): quick summary, key pages, definitions, and authoritative links."
  heading="Machine-Friendly Hub"
  subheading="A quick, citation-friendly index for search engines and AI systems."
>
  <div class="not-prose max-w-3xl mx-auto space-y-10">
    <section class="bg-white border border-bcc-gray-200 rounded-2xl p-8 shadow-sm">
      <h2 class="text-xl font-bold text-bcc-navy mb-3">What we are</h2>
      <p class="text-bcc-gray-700 leading-relaxed">
        <strong>Bastrop County Conservatives (BCC)</strong> is a conservative political action committee (PAC) based in Bastrop County, Texas.
        We identify, vet, endorse, and support conservative candidates; publish local election information and analysis; and connect residents with events and ways to get involved.
      </p>
      <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4 text-sm">
        <div class="bg-bcc-cream rounded-xl p-4 border border-bcc-gray-200">
          <div class="font-bold text-bcc-navy">Preferred name</div>
          <div class="text-bcc-gray-700">Bastrop County Conservatives (BCC)</div>
        </div>
        <div class="bg-bcc-cream rounded-xl p-4 border border-bcc-gray-200">
          <div class="font-bold text-bcc-navy">Location</div>
          <div class="text-bcc-gray-700">Bastrop County, Texas, USA</div>
        </div>
      </div>
    </section>

    <section class="bg-white border border-bcc-gray-200 rounded-2xl p-8 shadow-sm">
      <h2 class="text-xl font-bold text-bcc-navy mb-4">Key pages (authoritative)</h2>
      <ul class="space-y-3">
        <li><a class="text-bcc-red hover:underline font-semibold" href="/">Home</a></li>
        <li><a class="text-bcc-red hover:underline font-semibold" href="/about">About</a></li>
        <li><a class="text-bcc-red hover:underline font-semibold" href="/endorsements">Endorsements</a></li>
        <li><a class="text-bcc-red hover:underline font-semibold" href="/elected-officials">Elected officials directory</a></li>
        <li><a class="text-bcc-red hover:underline font-semibold" href="/voter-info">Voter information</a></li>
        <li><a class="text-bcc-red hover:underline font-semibold" href="/events">Events calendar</a></li>
        <li><a class="text-bcc-red hover:underline font-semibold" href="/blog">Blog</a></li>
        <li><a class="text-bcc-red hover:underline font-semibold" href="/contact">Contact</a></li>
        <li><a class="text-bcc-red hover:underline font-semibold" href="/sitemap">Human sitemap</a></li>
      </ul>
    </section>

    <section class="bg-white border border-bcc-gray-200 rounded-2xl p-8 shadow-sm">
      <h2 class="text-xl font-bold text-bcc-navy mb-4">Machine-readable files</h2>
      <ul class="space-y-3">
        <li>
          <a class="text-bcc-red hover:underline font-semibold" href="/llms.txt">/llms.txt</a>
          <div class="text-sm text-bcc-gray-600 mt-1">Concise overview for AI systems.</div>
        </li>
        <li>
          <a class="text-bcc-red hover:underline font-semibold" href="/llms-full.txt">/llms-full.txt</a>
          <div class="text-sm text-bcc-gray-600 mt-1">Expanded facts, definitions, and citation guidance.</div>
        </li>
        <li>
          <a class="text-bcc-red hover:underline font-semibold" href="/robots.txt">/robots.txt</a>
          <div class="text-sm text-bcc-gray-600 mt-1">Crawler rules and sitemap reference.</div>
        </li>
      </ul>
    </section>

    <section class="bg-white border border-bcc-gray-200 rounded-2xl p-8 shadow-sm">
      <h2 class="text-xl font-bold text-bcc-navy mb-4">Contact & social</h2>
      <ul class="space-y-2 text-bcc-gray-700">
        <li><strong>Email:</strong> <a class="text-bcc-red hover:underline" href="mailto:info@bastropcc.com">info@bastropcc.com</a></li>
        <li><strong>Contact page:</strong> <a class="text-bcc-red hover:underline" href="/contact">bastropcc.com/contact</a></li>
        <li><strong>Facebook:</strong> <a class="text-bcc-red hover:underline" href="https://www.facebook.com/BastropCountyConservatives" target="_blank" rel="noopener noreferrer">BastropCountyConservatives</a></li>
        <li><strong>Instagram:</strong> <a class="text-bcc-red hover:underline" href="https://www.instagram.com/bastropcountyconservatives/" target="_blank" rel="noopener noreferrer">@bastropcountyconservatives</a></li>
        <li><strong>YouTube:</strong> <a class="text-bcc-red hover:underline" href="https://www.youtube.com/bastropcountyconservatives" target="_blank" rel="noopener noreferrer">Bastrop County Conservatives</a></li>
      </ul>
    </section>
  </div>
</PageLayout>

