---

<PageLayout 
  title="Videos — Bastrop County Conservatives"
  heading="BCC Video Library"
  subheading="Watch interviews, candidate forums, and presentations from Bastrop County Conservatives meetings."
>

  <div class="text-center mb-10 not-prose">
    <a href="https://www.youtube.com/@BastropCountyConservatives" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-2 bg-bcc-red hover:bg-bcc-red-dark text-white font-bold px-6 py-3 rounded-lg transition-colors shadow-sm hover:shadow-md">
      <Icon name="lucide:youtube" class="w-5 h-5" />
      Subscribe on YouTube
    </a>
  </div>

  <div class="space-y-12 not-prose">
    {videos.map((video, idx) => (
      <article class="bg-white border border-bcc-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow">
        <div class="aspect-video">
          <iframe
            src={`https://www.youtube-nocookie.com/embed/${video.id}`}
            title={video.title}
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
            loading={idx < 3 ? "eager" : "lazy"}
            class="w-full h-full border-0"
          ></iframe>
        </div>
        <div class="p-6">
          <div class="flex flex-wrap items-center gap-3 mb-3">
            {video.date && (
              <span class="text-xs font-bold uppercase tracking-wider text-bcc-gray-500">
                {video.date}
              </span>
            )}
            {video.guest && (
              <span class="bg-bcc-cream text-bcc-navy px-3 py-0.5 rounded-full text-xs font-bold uppercase border border-bcc-gray-200">
                {video.guest}
              </span>
            )}
          </div>
          <h2 class="font-serif text-xl font-bold text-bcc-navy mb-3 leading-tight">{video.title}</h2>
          <p class="text-bcc-gray-600 leading-relaxed">{video.desc}</p>
        </div>
      </article>
    ))}
  </div>

</PageLayout>
