---
import BaseLayout from '../layouts/BaseLayout.astro';
import { generateWebSiteSchema } from '../utils/schema';
import Button from '../components/ui/Button.astro';
import EndorsementPopup from '../components/ui/EndorsementPopup.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import ValueCard from '../components/ui/ValueCard.astro';
import VideoEmbed from '../components/ui/VideoEmbed.astro';
import SubscribeForm from '../components/forms/SubscribeForm.astro';
import SectionDivider from '../components/ui/SectionDivider.astro';
import HeroSlider from '../components/HeroSlider.astro';
import { getCollection } from 'astro:content';
import { Icon } from 'astro-icon/components';

// Fetch collections

const videos = await getCollection('videos');
const recentVideos = videos.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf()).slice(0, 3);
---

<BaseLayout
  title="Bastrop County Conservatives — Local Action = National Wins"
  description="Bastrop County Conservatives PAC identifies, endorses, and supports conservative candidates in Bastrop County, Texas. Join our mission to uphold family values, faith, and freedom."
>
  <!-- Hero Slider -->
  <HeroSlider />

  <!-- Mission Strip -->
  <section class="bg-bcc-navy-dark text-white py-16 border-b-4 border-bcc-red">
    <div class="max-w-5xl mx-auto px-4 text-center">
      <p class="text-xl md:text-3xl font-serif leading-loose font-medium">
        "Our mission is to identify and support conservative political candidates by leveraging our network of liberty-minded members dedicated to family, faith, and freedom."
      </p>
    </div>
  </section>

  <!-- Local Election Endorsements -->
  <SectionDivider />
  
  <section class="py-16 md:py-24 bg-slate-50 scroll-reveal opacity-0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading 
        title="Local Candidates Endorsed by BCC" 
        subtitle="Make a plan to vote on Election Day: May 2nd (Early voting April 20th to April 28th)"
        centered={true}
      />
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 mt-12">
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-bcc-gray-200 group hover:border-bcc-red hover:shadow-2xl transition-all duration-300 flex flex-col">
          <div class="bg-bcc-red text-white text-center py-2 font-bold uppercase tracking-wider text-sm">Official Endorsement</div>
          <div class="p-8 text-center bg-gradient-to-b from-bcc-red/5 to-transparent flex flex-col flex-grow">
            <h3 class="font-bold text-bcc-navy text-2xl leading-tight mb-2 group-hover:text-bcc-red transition-colors">Wini Griffin</h3>
            <p class="text-bcc-gray-600 mb-8 font-medium">for Smithville City Council<br/>Place 4</p>
            <div class="mt-auto">
              <a href="https://voteforwini.com" target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-bcc-navy hover:bg-bcc-red text-white font-bold py-3 px-6 rounded-lg transition-colors shadow-md">Visit Website</a>
            </div>
          </div>
        </div>
        
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-bcc-gray-200 group hover:border-bcc-red hover:shadow-2xl transition-all duration-300 flex flex-col mt-4 md:mt-0">
          <div class="bg-bcc-red text-white text-center py-2 font-bold uppercase tracking-wider text-sm">Official Endorsement</div>
          <div class="p-8 text-center bg-gradient-to-b from-bcc-red/5 to-transparent flex flex-col flex-grow">
            <h3 class="font-bold text-bcc-navy text-2xl leading-tight mb-2 group-hover:text-bcc-red transition-colors">Daña Tovar</h3>
            <p class="text-bcc-gray-600 mb-8 font-medium">for Smithville City Council<br/>Place 5</p>
            <div class="mt-auto">
              <a href="https://electdanatovar.com" target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-bcc-navy hover:bg-bcc-red text-white font-bold py-3 px-6 rounded-lg transition-colors shadow-md">Visit Website</a>
            </div>
          </div>
        </div>
        
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-bcc-gray-200 group hover:border-bcc-red hover:shadow-2xl transition-all duration-300 flex flex-col mt-4 md:mt-0">
          <div class="bg-bcc-red text-white text-center py-2 font-bold uppercase tracking-wider text-sm">Official Endorsement</div>
          <div class="p-8 text-center bg-gradient-to-b from-bcc-red/5 to-transparent flex flex-col flex-grow">
            <h3 class="font-bold text-bcc-navy text-2xl leading-tight mb-2 group-hover:text-bcc-red transition-colors">Ishmael Harris</h3>
            <p class="text-bcc-gray-600 mb-8 font-medium">for Bastrop Mayor</p>
            <div class="mt-auto">
              <a href="https://www.ishmaelharrisformayor.com" target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-bcc-navy hover:bg-bcc-red text-white font-bold py-3 px-6 rounded-lg transition-colors shadow-md">Visit Website</a>
            </div>
          </div>
        </div>
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-bcc-gray-200 group hover:border-bcc-red hover:shadow-2xl transition-all duration-300 flex flex-col mt-4 md:mt-0">
          <div class="bg-bcc-red text-white text-center py-2 font-bold uppercase tracking-wider text-sm">Official Endorsement</div>
          <div class="p-8 text-center bg-gradient-to-b from-bcc-red/5 to-transparent flex flex-col flex-grow">
            <h3 class="font-bold text-bcc-navy text-2xl leading-tight mb-2 group-hover:text-bcc-red transition-colors">Chuck Swain</h3>
            <p class="text-bcc-gray-600 mb-8 font-medium">for Elgin City Council</p>
            <div class="mt-auto">
              <a href="https://www.elgintexas.gov/directory.aspx?EID=74" target="_blank" rel="noopener noreferrer" class="block w-full text-center bg-bcc-navy hover:bg-bcc-red text-white font-bold py-3 px-6 rounded-lg transition-colors shadow-md">Visit Website</a>
            </div>
          </div>
        </div>
      </div>
      
      <div class="mt-12 text-center">
        <Button href="/endorsements" variant="outline">View Full Endorsement History →</Button>
      </div>
    </div>
  </section>

  <!-- Election Resources -->
  <SectionDivider />
  
  <section class="py-16 md:py-24 bg-white scroll-reveal opacity-0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading 
        title="Election Resources" 
        subtitle="Know your officials, see our endorsements, and find your polling location."
        centered={true}
      />
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        <a href="/elected-officials" class="group bg-bcc-cream border border-bcc-gray-200 rounded-2xl p-8 text-center hover:shadow-lg hover:border-bcc-red transition-all duration-300">
          <div class="w-16 h-16 bg-bcc-navy text-bcc-gold rounded-full flex items-center justify-center mx-auto mb-5 group-hover:bg-bcc-red group-hover:text-white transition-colors">
            <Icon name="lucide:landmark" class="w-8 h-8" />
          </div>
          <h3 class="font-heading uppercase text-xl font-bold text-bcc-navy mb-3 group-hover:text-bcc-red transition-colors">Who Represents You</h3>
          <p class="text-bcc-gray-600 text-sm">Your complete guide to your elected officials — who they are, how to reach them, and when they're up for re-election.</p>
        </a>

        <a href="/endorsements" class="group bg-bcc-cream border border-bcc-gray-200 rounded-2xl p-8 text-center hover:shadow-lg hover:border-bcc-red transition-all duration-300">
          <div class="w-16 h-16 bg-bcc-navy text-bcc-gold rounded-full flex items-center justify-center mx-auto mb-5 group-hover:bg-bcc-red group-hover:text-white transition-colors">
            <Icon name="lucide:badge-check" class="w-8 h-8" />
          </div>
          <h3 class="font-heading uppercase text-xl font-bold text-bcc-navy mb-3 group-hover:text-bcc-red transition-colors">BCC Endorsements</h3>
          <p class="text-bcc-gray-600 text-sm">See who Bastrop County Conservatives has endorsed for the 2026 Republican Primary and why.</p>
        </a>

        <a href="/precinct-map" class="group bg-bcc-cream border border-bcc-gray-200 rounded-2xl p-8 text-center hover:shadow-lg hover:border-bcc-red transition-all duration-300">
          <div class="w-16 h-16 bg-bcc-navy text-bcc-gold rounded-full flex items-center justify-center mx-auto mb-5 group-hover:bg-bcc-red group-hover:text-white transition-colors">
            <Icon name="lucide:map" class="w-8 h-8" />
          </div>
          <h3 class="font-heading uppercase text-xl font-bold text-bcc-navy mb-3 group-hover:text-bcc-red transition-colors">Precinct Map</h3>
          <p class="text-bcc-gray-600 text-sm">Find your voting precinct, polling locations, and key election dates for Bastrop County.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- Core Values Preview -->
  <SectionDivider />
  
  <section class="py-16 md:py-24 bg-bcc-cream scroll-reveal opacity-0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading 
        title="Our Core Values" 
        subtitle="Principles that guide our actions and endorsements in Bastrop County."
        centered={true}
      />
      
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        <ValueCard 
          title="America First" 
          description="We believe in prioritizing the interests of American citizens and protecting our national sovereignty." 
          icon="lucide:flag" 
        />
        <ValueCard 
          title="Family" 
          description="The traditional family is the fundamental building block of a healthy society and culture." 
          icon="lucide:users" 
        />
        <ValueCard 
          title="Free Speech" 
          description="We defend the First Amendment and the right to express conservative viewpoints without censorship." 
          icon="lucide:message-square" 
        />
        <ValueCard 
          title="Life, Liberty, Pursuit of Happiness" 
          description="We stand for the unalienable rights bestowed by our Creator upon every individual." 
          icon="lucide:heart" 
        />
      </div>
      
      <div class="mt-12 text-center">
        <Button href="/about#values" variant="outline">View All 15 Core Values →</Button>
      </div>
    </div>
  </section>


  <!-- Recent Meeting Videos -->
  <SectionDivider />
  
  <section class="py-16 md:py-24 bg-bcc-cream scroll-reveal opacity-0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <SectionHeading 
        title="Prior Meetings" 
        subtitle="Watch full presentations from our latest Bastrop County gatherings."
      />
      
      <div class="flex overflow-x-auto pb-8 -mx-4 px-4 md:mx-0 md:px-0 md:grid md:grid-cols-3 gap-6 snap-x snap-mandatory" style="-webkit-overflow-scrolling: touch;">
        {recentVideos.map(video => (
          <div class="min-w-[85vw] md:min-w-0 snap-center md:snap-align-none">
            <VideoEmbed 
              youtubeId={video.data.youtubeId}
              title={video.data.title || `BCC Meeting with ${video.data.speaker}`}
              speaker={video.data.speaker}
              date={video.data.date}
              location={video.data.location}
              href="/videos"
            />
          </div>
        ))}
      </div>
      
      <div class="mt-8 text-center md:text-left">
        <Button href="/videos" variant="secondary">
          View All Videos →
        </Button>
      </div>
    </div>
  </section>

  <!-- Membership CTA Band -->
  <section class="bg-bcc-navy-dark py-16 text-white border-t-8 border-bcc-red scroll-reveal opacity-0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row items-center justify-between gap-8">
      <div class="max-w-2xl text-center md:text-left">
        <h2 class="font-heading uppercase text-white text-3xl md:text-4xl font-bold mb-4 tracking-wide">Have a Seat at the Table</h2>
        <p class="text-lg text-white font-medium">
          Membership gives you an opportunity to have a direct voice in our endorsement process.
        </p>
      </div>
      <div class="flex flex-col sm:flex-row gap-4 shrink-0 w-full md:w-auto mt-4 md:mt-0">
          <Button href="/membership#tiers" variant="primary">Join as a Member</Button>
        <Button href="/membership" variant="white-outline">Learn About Membership</Button>
      </div>
    </div>
  </section>

  <!-- Subscribe Section -->
  <section id="subscribe" class="py-20 md:py-32 bg-white scroll-mt-20 relative scroll-reveal opacity-0">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 mx-auto lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="font-heading uppercase text-3xl md:text-5xl font-bold text-bcc-navy mb-6 tracking-wide drop-shadow-sm">Stay Informed. <br/><span class="text-bcc-red">Stay Engaged.</span></h2>
          <p class="text-lg text-bcc-gray-600 mb-8 max-w-lg">
            Join our mailing list to receive critical updates on local issues, upcoming events, and candidate information straight to your inbox.
          </p>
        </div>
        
        <div class="bg-white lg:shadow-xl lg:rounded-2xl lg:p-8 border border-transparent lg:border-bcc-gray-100 flex justify-center">
          <SubscribeForm />
        </div>
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={generateWebSiteSchema()} />
  <EndorsementPopup />
</BaseLayout>
