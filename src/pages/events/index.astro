      { title:"Eden East Farm Stand", date:"2026-04-26", time:"9:00 AM - 1:00 PM", location:"Eden East, Bastrop", type:"community", org:"Eden East", desc:"Fresh local produce. Every Wednesday & Saturday.", url:"https://www.visitbastrop.com/events/" },
      { title:"Trivia Night", date:"2026-04-24", time:"7:00 PM - 9:00 PM", location:"Bastrop Beer Company", type:"community", org:"Bastrop Beer Co", desc:"Weekly trivia night every Thursday.", url:"https://www.visitbastrop.com/events/" },
      { title:"Wine Not? Wednesdays & Live Music", date:"2026-04-23", time:"5:00 PM - 8:00 PM", location:"Store House Market & Eatery, Bastrop", type:"community", org:"Store House", desc:"Weekly wine specials with live music.", url:"https://www.visitbastrop.com/events/" },
      { title:"Homeschoolers Day Out!", date:"2026-04-23", time:"10:00 AM", location:"Film Alley Bastrop", type:"community", org:"Film Alley", desc:"Special pricing for homeschool families every Wednesday.", url:"https://www.visitbastrop.com/events/" },
      { title:"Smithville Jamboree", date:"2026-04-24", time:"6:00 PM", location:"Smithville, TX", type:"community", org:"Smithville Chamber", desc:"Annual community celebration in Smithville.", url:"https://www.smithvillejamboree.com" },
      { title:"First Friday Art Walk", date:"2026-05-02", time:"5:00 PM - 8:00 PM", location:"Downtown Bastrop", type:"community", org:"Bastrop Art Gallery", desc:"Monthly art walk featuring local artists and live music on Main Street.", url:"https://www.visitbastrop.com/events/" },
      { title:"Bastrop Farmers Market", date:"2026-04-26", time:"9:00 AM - 1:00 PM", location:"Bastrop Convention Center Parking Lot", type:"community", org:"Bastrop Farmers Market", desc:"Weekly farmers market every Saturday.", url:"https://www.visitbastrop.com/events/" },
      { title:"Bastrop Farmers Market", date:"2026-05-03", time:"9:00 AM - 1:00 PM", location:"Bastrop Convention Center Parking Lot", type:"community", org:"Bastrop Farmers Market", desc:"Weekly farmers market every Saturday.", url:"https://www.visitbastrop.com/events/" },
      // Political Events — BCRP (bastropctygop.com)
      { title:"BCRP April Monthly Informational Meeting", date:"2026-04-26", time:"6:00 PM", location:"BCRP Meeting Space, 443 Hwy 71 West, Bastrop, TX 78602", type:"political", org:"Bastrop County GOP", desc:"Doors open at 6 PM, discussion begins at 6:30 PM. Monthly informational meeting of the Bastrop County Republican Party.", url:"https://www.bastropctygop.com/events/monthly-meeting-april-2026/" },
      { title:"BCRP 4th Annual Golf Classic", date:"2026-04-10", time:"12:00 PM", location:"ColoVista Golf Club, 100 Country Club Dr, Bastrop, TX", type:"political", org:"Bastrop County GOP", desc:"Four Man Scramble. Check-in 11 AM, Shotgun Start 12 PM. Individual $85 / Foursome $340. Flagship fundraiser for the Bastrop County Republican Party.", url:"https://www.bastropctygop.com/events/golf-classic/" },
      { title:"Smithville Jamboree Parade — BCRP Float", date:"2026-04-10", time:"10:00 AM", location:"Smithville Recreation Center, 106 Royston St, Smithville, TX", type:"political", org:"Bastrop County GOP", desc:"Meet at 10 AM to decorate the trailer, ride on the parade float at 1:15 PM. Wear patriotic attire!", url:"https://www.bastropctygop.com/events/smithville-jamboree-parade/" },
      // Political Events — BCC / County / RPT
      { title:"BCC Monthly Membership Meeting", date:"2026-05-08", time:"6:00 PM - 8:00 PM", location:"Casa Chapala, 100 Main St, Bastrop", type:"political", org:"BastropCC", desc:"Monthly meeting featuring guest speakers, legislative updates, and fellowship.", url:"https://bastropcc.com/membership" },
      { title:"Bastrop County Commissioners Court", date:"2026-04-28", time:"9:00 AM", location:"Bastrop County Courthouse, 804 Pecan St", type:"political", org:"Bastrop County", desc:"Regular meeting of the Bastrop County Commissioners Court. Open to the public.", url:"https://www.co.bastrop.tx.us" },
      { title:"Bastrop County Commissioners Court", date:"2026-05-12", time:"9:00 AM", location:"Bastrop County Courthouse, 804 Pecan St", type:"political", org:"Bastrop County", desc:"Regular meeting of the Bastrop County Commissioners Court. Open to the public.", url:"https://www.co.bastrop.tx.us" },
      { title:"RPT State Convention", date:"2026-06-12", time:"All Day", location:"Dallas Convention Center, Dallas, TX", type:"political", org:"Republican Party of Texas", desc:"2026 Republican Party of Texas State Convention. June 12–14.", url:"https://texasgop.org/events/" },
      { title:"RPT State Convention", date:"2026-06-13", time:"All Day", location:"Dallas Convention Center, Dallas, TX", type:"political", org:"Republican Party of Texas", desc:"2026 Republican Party of Texas State Convention. Day 2.", url:"https://texasgop.org/events/" },
      { title:"RPT State Convention", date:"2026-06-14", time:"All Day", location:"Dallas Convention Center, Dallas, TX", type:"political", org:"Republican Party of Texas", desc:"2026 Republican Party of Texas State Convention. Final day.", url:"https://texasgop.org/events/" },
    ];

    let EVENTS = [...SEED_EVENTS];
    const EVENT_TYPES = { political: { label: 'Political', color: '#991b1b' }, community: { label: 'Community', color: '#059669' } };
    const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const DAYS_SHORT = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

    let currentDate = new Date(new Date().getFullYear(), new Date().getMonth(), 1);
    let currentView = 'list';
    let activeTypeFilters = new Set(['political', 'community']);

    async function loadAPIEvents() {
      try {
        const res = await fetch('https://bastropcc-api.communications-b08.workers.dev/api/v1/public/events');
        const data = await res.json();
        if (data.success && data.data) {
          const apiEvents = data.data.map(ev => ({ ...ev, url: ev.event_url, desc: ev.description }));
          // Merge: dedup by title+date
          const existingKeys = new Set(EVENTS.map(e => e.title + '|' + e.date));
          apiEvents.forEach(ev => { if (!existingKeys.has(ev.title + '|' + ev.date)) EVENTS.push(ev); });
        }
      } catch (err) { console.error('API fetch error:', err); }
    }

    function init() {
      buildTypeFilters();
      if (window.innerWidth <= 700) currentView = 'list';
      loadAPIEvents().then(() => render());
      render(); // render seeds immediately
      document.getElementById('prevMonth').addEventListener('click', () => { currentDate.setMonth(currentDate.getMonth() - 1); render(); });
      document.getElementById('nextMonth').addEventListener('click', () => { currentDate.setMonth(currentDate.getMonth() + 1); render(); });
      document.getElementById('modalOverlay').addEventListener('click', (e) => { if (e.target === e.currentTarget) closeModal(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
    }
    document.addEventListener('DOMContentLoaded', init);

    function buildTypeFilters() {
      const typePills = document.getElementById('typePills');
      if (!typePills) return;
      typePills.innerHTML = '<button class="type-pill active" data-type-filter="all">All Events</button>' +
        Object.entries(EVENT_TYPES).map(([key, val]) =>
          '<button class="type-pill active" data-type-filter="' + key + '"><span class="pill-dot" style="background:' + val.color + '"></span>' + val.label + '</button>'
        ).join('');
      typePills.querySelectorAll('.type-pill').forEach(btn => btn.addEventListener('click', () => toggleTypeFilter(btn)));
    }

    window.toggleTypeFilter = function(btn) {
      const filter = btn.dataset.typeFilter;
      if (filter === 'all') {
        const allActive = activeTypeFilters.size === Object.keys(EVENT_TYPES).length;
        if (allActive) { activeTypeFilters.clear(); document.querySelectorAll('.type-pill').forEach(p => p.classList.remove('active')); }
        else { activeTypeFilters = new Set(Object.keys(EVENT_TYPES)); document.querySelectorAll('.type-pill').forEach(p => p.classList.add('active')); }
      } else {
        const allBtn = document.querySelector('[data-type-filter="all"]');
        if (activeTypeFilters.has(filter)) { activeTypeFilters.delete(filter); btn.classList.remove('active'); }
        else { activeTypeFilters.add(filter); btn.classList.add('active'); }
        allBtn.classList.toggle('active', activeTypeFilters.size === Object.keys(EVENT_TYPES).length);
      }
      render();
    };

    window.setView = function(view) {
      currentView = view;
      document.getElementById('btnCalendar').classList.toggle('active', view === 'calendar');
      document.getElementById('btnList').classList.toggle('active', view === 'list');
      render();
    };

    function render() {
      const year = currentDate.getFullYear(), month = currentDate.getMonth();
      document.getElementById('currentMonth').textContent = MONTHS[month] + ' ' + year;
      const calWrap = document.getElementById('calGridWrap'), listView = document.getElementById('listView');
      if (currentView === 'calendar') { calWrap.classList.remove('hidden'); listView.classList.remove('active'); renderCalendar(year, month); }
      else { calWrap.classList.add('hidden'); listView.classList.add('active'); renderList(year, month); }
    }

    function getFilteredEvents() { return EVENTS.filter(e => activeTypeFilters.has(e.type)); }

    function renderCalendar(year, month) {
      const grid = document.getElementById('calGrid');
      const firstDay = new Date(year, month, 1).getDay();
      const daysInMonth = new Date(year, month + 1, 0).getDate();
      const daysInPrev = new Date(year, month, 0).getDate();
      const today = new Date();
      let html = DAYS_SHORT.map(d => '<div class="cal-header">' + d + '</div>').join('');
      const filtered = getFilteredEvents();
      const eventsByDate = {};
      filtered.forEach(e => { if (!eventsByDate[e.date]) eventsByDate[e.date] = []; eventsByDate[e.date].push(e); });
      for (let i = firstDay - 1; i >= 0; i--) html += '<div class="cal-day other-month"><span class="day-num">' + (daysInPrev - i) + '</span></div>';
      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = year + '-' + String(month + 1).padStart(2, '0') + '-' + String(d).padStart(2, '0');
        const isToday = today.getFullYear() === year && today.getMonth() === month && today.getDate() === d;
        const dayEvents = eventsByDate[dateStr] || [];
        html += '<div class="cal-day' + (isToday ? ' today' : '') + (dayEvents.length ? ' has-events' : '') + '">';
        html += '<span class="day-num">' + d + '</span>';
        dayEvents.slice(0, 3).forEach(ev => { html += '<div class="cal-event type-' + ev.type + '" onclick="openModal(' + EVENTS.indexOf(ev) + ')" title="' + ev.title + '">' + ev.title + '</div>'; });
        if (dayEvents.length > 3) html += '<div class="cal-more" onclick="showDayEvents(\'' + dateStr + '\')">+' + (dayEvents.length - 3) + ' more</div>';
        html += '</div>';
      }
      const totalCells = firstDay + daysInMonth, remaining = (7 - (totalCells % 7)) % 7;
      for (let i = 1; i <= remaining; i++) html += '<div class="cal-day other-month"><span class="day-num">' + i + '</span></div>';
      grid.innerHTML = html;
    }

    function renderList(year, month) {
      const listView = document.getElementById('listView');
      const filtered = getFilteredEvents().filter(e => { const d = new Date(e.date + 'T00:00:00'); return d.getFullYear() === year && d.getMonth() === month; }).sort((a, b) => a.date.localeCompare(b.date));
      if (filtered.length === 0) { listView.innerHTML = '<div style="text-align:center;padding:3rem;color:var(--text-dim);"><p style="font-size:1.1rem;margin-bottom:0.5rem;">No events this month</p><p style="font-size:0.85rem;">Try a different month or adjust your filters.</p></div>'; return; }
      let html = '<div class="list-month-group"><div class="list-month-label">' + MONTHS[month] + ' ' + year + '</div>';
      filtered.forEach((ev, i) => {
        const d = new Date(ev.date + 'T00:00:00');
        const typeConf = EVENT_TYPES[ev.type] || EVENT_TYPES.community;
        html += '<div class="list-event" onclick="openModal(' + EVENTS.indexOf(ev) + ')" style="animation-delay:' + (i * 0.04) + 's">' +
          '<div class="list-date"><div class="weekday">' + DAYS_SHORT[d.getDay()] + '</div><div class="day">' + d.getDate() + '</div></div>' +
          '<div class="list-info">' +
          '<span class="org-badge" style="background:' + typeConf.color + ';color:#fff">' + (ev.org || ev.type) + '</span>' +
          '<span class="type-badge ' + ev.type + '">' + (ev.type === 'political' ? '★ Political' : '⌂ Community') + '</span>' +
          '<h3>' + ev.title + '</h3>' +
          '<div class="time-loc"><strong>' + ev.time + '</strong>' + (ev.location ? ' · ' + ev.location.split(',')[0] : '') + '</div>' +
          '</div></div>';
      });
      html += '</div>';
      listView.innerHTML = html;
    }

    window.openModal = function(idx) {
      const ev = EVENTS[idx]; if (!ev) return;
      const d = new Date(ev.date + 'T00:00:00');
      const typeConf = EVENT_TYPES[ev.type] || EVENT_TYPES.community;
      const dateStr = DAYS_SHORT[d.getDay()] + ', ' + MONTHS[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear();
      const gcalDate = ev.date.replace(/-/g, '');
      const gcalUrl = 'https://www.google.com/calendar/render?action=TEMPLATE&text=' + encodeURIComponent(ev.title) + '&dates=' + gcalDate + '/' + gcalDate + '&details=' + encodeURIComponent(ev.desc || '') + '&location=' + encodeURIComponent(ev.location || '');
      document.getElementById('modal').innerHTML =
        '<button class="modal-close" onclick="closeModal()">✕</button>' +
        '<h2>' + ev.title + '</h2>' +
        '<span class="modal-org" style="background:' + typeConf.color + ';color:#fff">' + (ev.org || ev.type) + '</span>' +
        '<span class="type-badge ' + ev.type + '" style="display:inline-block;margin-left:6px;font-size:0.7rem;padding:3px 10px;border-radius:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;' + (ev.type === 'political' ? 'background:#fde8e8;color:#991b1b;' : 'background:#e8f5e9;color:#1b5e20;') + '">' + (ev.type === 'political' ? '★ Political' : '⌂ Community') + '</span>' +
        '<div class="detail-row"><span class="icon">📅</span><span class="detail-text">' + dateStr + '</span></div>' +
        '<div class="detail-row"><span class="icon">🕐</span><span class="detail-text">' + ev.time + '</span></div>' +
        (ev.location ? '<div class="detail-row"><span class="icon">📍</span><span class="detail-text">' + ev.location + '</span></div>' : '') +
        (ev.desc ? '<div class="detail-row"><span class="icon">📋</span><span class="detail-text">' + ev.desc + '</span></div>' : '') +
        '<div class="modal-actions">' +
        (ev.url ? '<a href="' + ev.url + '" target="_blank" class="btn-primary">Visit Website →</a>' : '') +
        '<a href="' + gcalUrl + '" target="_blank" class="btn-secondary">+ Google Calendar</a></div>';
      document.getElementById('modalOverlay').classList.add('show');
    };
    window.closeModal = function() { document.getElementById('modalOverlay').classList.remove('show'); };
    window.showDayEvents = function(dateStr) { const d = new Date(dateStr + 'T00:00:00'); currentDate = new Date(d.getFullYear(), d.getMonth(), 1); setView('list'); };
  </script>

</PageLayout>
