---
import PageLayout from '../../layouts/PageLayout.astro';
import { generateEventsListSchema } from '../../utils/schema';

type PublicEvent = {
  title: string;
  date: string;
  location: string;
  description?: string;
  event_url?: string;
  org?: string;
};

const LAST_UPDATED = '2026-04-27';

async function fetchPublicEvents(): Promise<PublicEvent[]> {
  try {
    const res = await fetch('https://bastropcc-api.communications-b08.workers.dev/api/v1/public/events');
    const json = await res.json();
    if (!json?.success || !Array.isArray(json?.data)) return [];
    return json.data as PublicEvent[];
  } catch {
    return [];
  }
}

const apiEvents = await fetchPublicEvents();
const now = new Date();
const upcoming = apiEvents
  .filter((e) => {
    const d = new Date(`${e.date}T00:00:00`);
    return Number.isFinite(d.valueOf()) && d >= new Date(now.getFullYear(), now.getMonth(), now.getDate());
  })
  .sort((a, b) => a.date.localeCompare(b.date))
  .slice(0, 25);

const eventsSchema = generateEventsListSchema(
  upcoming.map((e) => ({
    name: e.title,
    startDate: new Date(`${e.date}T00:00:00`).toISOString(),
    location: e.location,
    description: e.description || '',
    url: e.event_url || undefined,
    organizer: e.org || 'Bastrop County Conservatives',
  }))
);
---

<PageLayout 
  title="Bastrop County Events Calendar — Community & Political Events"
  description="Your central calendar for Bastrop County events — community festivals, live music, political meetings, and more. Sourced from Visit Bastrop, Bastrop Chamber, and local organizations."
  heading="Bastrop County Events"
  subheading="Community & Political Events Calendar"
>
  <div class="calendar-wrapper">
    <div class="controls" id="controls">
      <div class="month-nav hidden" id="monthNav">
        <button id="prevMonth" aria-label="Previous month">‹</button>
        <span class="current-month" id="currentMonth"></span>
        <button id="nextMonth" aria-label="Next month">›</button>
      </div>
      <div class="upcoming-label show" id="upcomingLabel">Next 60 Days</div>
      <div class="view-toggle">
        <button class="active" id="btnUpcoming" onclick="setView('upcoming')">Upcoming</button>
        <button id="btnCalendar" onclick="setView('calendar')">Month</button>
      </div>
    </div>

    <div class="calendar-container">
      <div class="filter-section" id="filterSection">
        <div class="search-row">
          <label for="eventSearch" class="visually-hidden">Search events</label>
          <div class="search-wrap">
            <span class="search-icon" aria-hidden="true">🔍</span>
            <input
              type="search"
              id="eventSearch"
              class="event-search-input"
              placeholder="Search events by title, organizer, location, or description…"
              autocomplete="off"
              spellcheck="false"
            />
            <button type="button" class="search-clear" id="searchClear" aria-label="Clear search" hidden>✕</button>
          </div>
          <span class="search-result-count" id="searchResultCount" aria-live="polite"></span>
        </div>
        <div class="type-filter-row" id="typeFilterRow">
          <span class="filter-row-label">Type:</span>
          <div class="type-pills" id="typePills"></div>
        </div>
        <div class="org-filter-row" id="orgFilterRow">
          <span class="filter-row-label">Organizers:</span>
          <div class="org-pills" id="orgPills"></div>
          <button type="button" class="org-toggle" id="orgToggle" aria-expanded="false">Show all</button>
        </div>
      </div>

      <div class="cal-grid-wrap" id="calGridWrap">
        <div class="cal-grid" id="calGrid"></div>
      </div>
      <div class="list-view" id="listView"></div>
    </div>
    
    <!-- Submit Event Form -->
    <div class="submit-event-section" id="submit-event">
      <h3 class="submit-title">Submit an Event</h3>
      <p class="submit-desc">Have an event to share with Bastrop County? Submit it below and our team will review it for the calendar.</p>
      
      <form action="https://formsubmit.co/info@bastropcc.com" method="POST" id="event-submit-form" class="submit-form">
        <input type="hidden" name="_subject" value="BCC Website - New Event Submission">
        <input type="hidden" name="_captcha" value="false">
        <input type="hidden" name="_next" value="https://bastropcc.com/event-submitted">
        <input type="text" name="_honey" style="display:none">
        
        <div class="form-grid">
          <div class="form-full">
            <label for="event_title">Event Title <span class="req">*</span></label>
            <input type="text" id="event_title" name="EVENT_TITLE" required>
          </div>
          <div>
            <label for="event_date">Date <span class="req">*</span></label>
            <input type="date" id="event_date" name="EVENT_DATE" required>
          </div>
          <div>
            <label for="event_time">Time <span class="req">*</span></label>
            <input type="text" id="event_time" name="EVENT_TIME" placeholder="e.g. 6:00 PM" required>
          </div>
          <div class="form-full">
            <label for="event_location">Location <span class="req">*</span></label>
            <input type="text" id="event_location" name="EVENT_LOCATION" placeholder="Full address or venue name" required>
          </div>
          <div>
            <label for="event_type">Event Type</label>
            <select id="event_type" name="EVENT_TYPE">
              <option value="community">Community</option>
              <option value="political">Political</option>
            </select>
          </div>
          <div>
            <label for="event_org">Hosting Organization</label>
            <input type="text" id="event_org" name="EVENT_ORG">
          </div>
          <div class="form-full">
            <label for="event_url">Event URL / Link</label>
            <input type="url" id="event_url" name="EVENT_URL" placeholder="https://">
          </div>
          <div class="form-full">
            <label for="event_desc">Additional Details</label>
            <textarea id="event_desc" name="EVENT_DESC" rows="3"></textarea>
          </div>
        </div>
        
        <div class="form-actions">
          <button type="submit" class="submit-btn">Submit Event</button>
        </div>
      </form>
    </div>

    <div class="cal-footer">
      <p>Maintained by <a href="https://bastropcc.com">Bastrop County Conservatives</a> · Events sourced from partner organizations across Bastrop County</p>
      <p class="mt-3 text-xs text-bcc-gray-500">BCC reserves the right to deny any individual(s) attendance at any meeting or event.</p>
    </div>

    <div class="modal-overlay" id="modalOverlay">
      <div class="modal" id="modal"></div>
    </div>
  </div>

  <style is:global>
    .calendar-wrapper {
      --navy: #1a2b4a; --navy-mid: #243656; --gold: #c9a84c;
      --red: #b91c1c; --cream: #faf8f4; --white: #ffffff;
      --border: #e5e2db; --text: #1a2b4a; --text-dim: #6b7280;
      --radius: 8px; --shadow: 0 2px 12px rgba(0,0,0,0.08);
      font-family: 'Inter', -apple-system, sans-serif;
      color: var(--text); line-height: 1.5; -webkit-font-smoothing: antialiased; width: 100%;
    }
    .calendar-wrapper .controls {
      display: flex; flex-wrap: wrap; justify-content: center; align-items: center;
      gap: 1rem; padding: 1rem 1.5rem; background: var(--cream);
      border: 1px solid var(--border); border-radius: var(--radius); margin-bottom: 1.5rem;
    }
    .calendar-wrapper .month-nav { display: flex; align-items: center; gap: 0.75rem; }
    .calendar-wrapper .month-nav button {
      background: var(--white); border: 1px solid var(--border); color: var(--navy);
      width: 36px; height: 36px; border-radius: 50%; cursor: pointer; font-size: 1.1rem;
      display: flex; align-items: center; justify-content: center; transition: all 0.2s; font-weight: 700;
    }
    .calendar-wrapper .month-nav button:hover { background: var(--navy); color: var(--white); border-color: var(--navy); }
    .calendar-wrapper .month-nav .current-month {
      font-family: 'Playfair Display', 'Oswald', serif; font-weight: 700; font-size: 1.25rem;
      min-width: 200px; text-align: center; color: var(--navy); text-transform: uppercase; letter-spacing: 0.04em;
    }
    .calendar-wrapper .month-nav.hidden { display: none; }
    .calendar-wrapper .upcoming-label {
      display: none; font-family: 'Playfair Display', 'Oswald', serif; font-weight: 700; font-size: 1.25rem;
      text-align: center; color: var(--navy); text-transform: uppercase; letter-spacing: 0.04em; padding: 0 0.5rem;
    }
    .calendar-wrapper .upcoming-label.show { display: inline-block; }
    .calendar-wrapper .view-toggle {
      display: flex; background: var(--white); border-radius: 20px; overflow: hidden; border: 1px solid var(--border);
    }
    .calendar-wrapper .view-toggle button {
      background: transparent; border: none; color: var(--text-dim); padding: 7px 18px; cursor: pointer;
      font-size: 0.8rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; transition: all 0.2s;
    }
    .calendar-wrapper .view-toggle button.active { background: var(--navy); color: var(--white); }
    .calendar-wrapper .filter-section {
      margin-bottom: 1.25rem; background: var(--cream); border: 1px solid var(--border);
      border-radius: var(--radius); padding: 0.75rem 1rem;
    }
    .calendar-wrapper .visually-hidden {
      position: absolute !important; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden;
      clip: rect(0,0,0,0); white-space: nowrap; border: 0;
    }
    .calendar-wrapper .search-row {
      display: flex; flex-wrap: wrap; align-items: center; gap: 0.6rem;
      margin-bottom: 0.6rem; padding-bottom: 0.6rem; border-bottom: 1px dashed var(--border);
    }
    .calendar-wrapper .search-wrap {
      position: relative; flex: 1 1 320px; display: flex; align-items: center;
    }
    .calendar-wrapper .search-icon {
      position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
      color: var(--text-dim); font-size: 0.85rem; pointer-events: none;
    }
    .calendar-wrapper .event-search-input {
      width: 100%; padding: 9px 38px 9px 36px; border: 1px solid var(--border); border-radius: 20px;
      background: var(--white); font-size: 0.88rem; color: var(--text); font-family: inherit;
      transition: border-color 0.15s, box-shadow 0.15s; box-sizing: border-box;
    }
    .calendar-wrapper .event-search-input::-webkit-search-cancel-button { -webkit-appearance: none; }
    .calendar-wrapper .event-search-input::placeholder { color: var(--text-dim); }
    .calendar-wrapper .event-search-input:focus {
      outline: none; border-color: var(--navy); box-shadow: 0 0 0 3px rgba(26, 43, 74, 0.12);
    }
    .calendar-wrapper .search-clear {
      position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
      background: var(--cream); border: 1px solid var(--border); color: var(--text-dim);
      width: 22px; height: 22px; border-radius: 50%; cursor: pointer; font-size: 0.7rem;
      display: flex; align-items: center; justify-content: center; transition: all 0.15s; padding: 0;
    }
    .calendar-wrapper .search-clear:hover { background: var(--navy); color: var(--white); border-color: var(--navy); }
    .calendar-wrapper .search-clear[hidden] { display: none; }
    .calendar-wrapper .search-result-count {
      font-size: 0.72rem; color: var(--text-dim); font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap;
    }
    .calendar-wrapper .search-result-count.has-query { color: var(--navy); }
    .calendar-wrapper .search-result-count em {
      font-style: normal; color: var(--red); font-weight: 700;
    }
    @media (max-width: 700px) {
      .calendar-wrapper .search-wrap { flex-basis: 100%; }
      .calendar-wrapper .event-search-input { font-size: 0.82rem; padding: 8px 34px 8px 32px; }
      .calendar-wrapper .search-result-count { width: 100%; text-align: center; }
    }
    .calendar-wrapper .type-filter-row {
      display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem; justify-content: center;
    }
    .calendar-wrapper .filter-row-label {
      font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
      color: var(--text-dim); margin-right: 0.25rem; white-space: nowrap;
    }
    .calendar-wrapper .type-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; justify-content: center; }
    .calendar-wrapper .type-pill {
      display: inline-flex; align-items: center; gap: 6px; font-size: 0.72rem; padding: 5px 14px;
      border-radius: 14px; border: 1px solid var(--navy); background: var(--navy); color: var(--white);
      cursor: pointer; font-weight: 600; transition: all 0.2s; white-space: nowrap;
    }
    .calendar-wrapper .type-pill .pill-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .calendar-wrapper .type-pill:hover { background: var(--navy-mid); }
    .calendar-wrapper .type-pill.active { background: var(--white); border-color: var(--border); color: var(--text-dim); }
    .calendar-wrapper .type-pill.active:hover { border-color: var(--navy); color: var(--navy); }

    .calendar-wrapper .org-filter-row {
      display: flex; flex-wrap: wrap; align-items: flex-start; gap: 0.5rem;
      justify-content: center; margin-top: 0.6rem; padding-top: 0.6rem;
      border-top: 1px dashed var(--border);
    }
    .calendar-wrapper .org-filter-row .filter-row-label { padding-top: 4px; }
    .calendar-wrapper .org-pills {
      display: flex; flex-wrap: wrap; gap: 0.35rem; justify-content: center;
      flex: 1 1 auto; max-height: 38px; overflow: hidden; transition: max-height 0.25s ease;
    }
    .calendar-wrapper .org-pills.expanded { max-height: 360px; }
    .calendar-wrapper .org-pill {
      display: inline-flex; align-items: center; font-size: 0.68rem; padding: 4px 10px;
      border-radius: 12px; border: 1px solid var(--navy); background: var(--navy); color: var(--white);
      cursor: pointer; font-weight: 600; transition: all 0.15s; white-space: nowrap;
    }
    .calendar-wrapper .org-pill:hover { background: var(--navy-mid); }
    .calendar-wrapper .org-pill.active { background: var(--white); border-color: var(--border); color: var(--text-dim); }
    .calendar-wrapper .org-pill.active:hover { border-color: var(--navy); color: var(--navy); }
    .calendar-wrapper .org-pill.all-orgs { background: var(--gold); border-color: var(--gold); color: var(--navy); }
    .calendar-wrapper .org-pill.all-orgs:hover { background: #b89640; border-color: #b89640; }
    .calendar-wrapper .org-pill.all-orgs.active { background: var(--white); border-color: var(--border); color: var(--text-dim); }
    .calendar-wrapper .org-toggle {
      background: transparent; border: 1px solid var(--border); color: var(--navy);
      font-size: 0.65rem; padding: 4px 10px; border-radius: 12px; cursor: pointer;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
      transition: all 0.15s; white-space: nowrap; align-self: flex-start;
    }
    .calendar-wrapper .org-toggle:hover { background: var(--navy); color: var(--white); border-color: var(--navy); }
    .calendar-wrapper .type-badge { display: inline-block; font-size: 0.6rem; padding: 2px 8px; border-radius: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.04em; margin-left: 6px; vertical-align: middle; }
    .calendar-wrapper .type-badge.political { background: #fde8e8; color: #991b1b; }
    .calendar-wrapper .type-badge.community { background: #e8f5e9; color: #1b5e20; }

    /* Source Strip */
    .calendar-wrapper .source-strip {
      display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 0.5rem;
      padding: 0.6rem 1rem; margin-bottom: 1.25rem; background: var(--white);
      border: 1px solid var(--border); border-radius: var(--radius);
    }
    .calendar-wrapper .source-strip .source-label {
      font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em; color: var(--text-dim);
    }
    .calendar-wrapper .source-strip .source-links { display: flex; flex-wrap: wrap; gap: 0.4rem; }
    .calendar-wrapper .source-strip .source-links a {
      font-size: 0.7rem; padding: 3px 10px; border-radius: 12px; background: var(--cream);
      border: 1px solid var(--border); color: var(--navy); text-decoration: none; font-weight: 600; transition: all 0.2s;
    }
    .calendar-wrapper .source-strip .source-links a:hover { background: var(--navy); color: var(--white); border-color: var(--navy); }

    /* Calendar Grid */
    .calendar-wrapper .calendar-container { max-width: 1100px; margin: 0 auto; }
    .calendar-wrapper .cal-grid {
      display: grid; grid-template-columns: repeat(7, 1fr); gap: 0; background: var(--white);
      border-radius: var(--radius); overflow: hidden; border: 2px solid var(--navy);
    }
    .calendar-wrapper .cal-header {
      background: var(--navy); padding: 12px 4px; text-align: center; font-size: 0.72rem;
      font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--white);
      border-right: 1px solid rgba(255,255,255,0.15);
    }
    .calendar-wrapper .cal-header:last-child { border-right: none; }
    .calendar-wrapper .cal-day {
      background: var(--white); min-height: 110px; padding: 8px; position: relative;
      transition: background 0.15s; cursor: default; border-right: 1px solid var(--border); border-bottom: 1px solid var(--border);
    }
    .calendar-wrapper .cal-grid > div:not(.cal-header):nth-child(7n + 7) { border-right: none; }
    .calendar-wrapper .cal-day:hover { background: var(--cream); }
    .calendar-wrapper .cal-day.other-month { background: #f9f8f6; opacity: 0.45; }
    .calendar-wrapper .cal-day.today { box-shadow: inset 0 0 0 2px var(--red); background: #fef7f7; }
    .calendar-wrapper .cal-day .day-num { font-size: 0.8rem; font-weight: 600; color: var(--text-dim); margin-bottom: 4px; display: block; }
    .calendar-wrapper .cal-day.today .day-num { color: var(--red); font-weight: 800; }
    .calendar-wrapper .cal-event {
      font-size: 0.65rem; padding: 3px 5px; border-radius: 3px; margin-bottom: 3px; cursor: pointer;
      white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: 600; line-height: 1.4; transition: filter 0.15s;
    }
    .calendar-wrapper .cal-event:hover { filter: brightness(1.15); }
    .calendar-wrapper .cal-event.type-political { background: #b91c1c; color: #fff; }
    .calendar-wrapper .cal-event.type-community { background: #059669; color: #fff; }
    .calendar-wrapper .cal-more { font-size: 0.65rem; color: var(--red); font-weight: 700; cursor: pointer; padding: 1px 4px; }

    /* List View */
    .calendar-wrapper .list-view { display: none; }
    .calendar-wrapper .list-view.active { display: block; }
    .calendar-wrapper .cal-grid-wrap { display: block; }
    .calendar-wrapper .cal-grid-wrap.hidden { display: none; }
    .calendar-wrapper .list-month-group { margin-bottom: 2rem; }
    .calendar-wrapper .list-month-label {
      font-family: 'Playfair Display', 'Oswald', serif; font-weight: 700; font-size: 1.2rem; color: var(--navy);
      border-bottom: 2px solid var(--border); padding-bottom: 0.5rem; margin-bottom: 0.8rem;
      text-transform: uppercase; letter-spacing: 0.04em;
    }
    .calendar-wrapper .list-event {
      display: grid; grid-template-columns: 70px 1fr; gap: 1rem; padding: 0.8rem 0.5rem;
      border-bottom: 1px solid var(--border); transition: background 0.15s; cursor: pointer;
      border-radius: var(--radius); text-align: left; animation: fadeSlide 0.3s ease both;
    }
    .calendar-wrapper .list-event:hover { background: var(--cream); }
    .calendar-wrapper .list-date { text-align: center; padding-top: 2px; }
    .calendar-wrapper .list-date .day { font-family: 'Playfair Display', 'Oswald', serif; font-weight: 800; font-size: 1.6rem; color: var(--navy); line-height: 1; }
    .calendar-wrapper .list-date .weekday { font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-dim); font-weight: 700; display: block; }
    .calendar-wrapper .list-info h3 { font-size: 1rem; font-weight: 700; color: var(--navy); margin-bottom: 0.25rem; margin-top: 0; text-transform: none; letter-spacing: 0; }
    .calendar-wrapper .list-info .org-badge {
      display: inline-block; font-size: 0.65rem; padding: 2px 8px; border-radius: 10px;
      font-weight: 700; margin-right: 6px; margin-bottom: 4px; vertical-align: middle;
    }
    .calendar-wrapper .list-info .time-loc { font-size: 0.85rem; color: var(--text-dim); }
    .calendar-wrapper .list-info .time-loc strong { color: var(--red); font-weight: 700; }

    /* Modal */
    .calendar-wrapper .modal-overlay {
      display: none; position: fixed; inset: 0; background: rgba(26, 43, 74, 0.65); z-index: 1000;
      backdrop-filter: blur(6px); justify-content: center; align-items: center; padding: 1.5rem;
    }
    .calendar-wrapper .modal-overlay.show { display: flex; }
    .calendar-wrapper .modal {
      background: var(--white); border: 1px solid var(--border); border-radius: 12px; max-width: 520px;
      width: 100%; padding: 2rem; position: relative; box-shadow: 0 8px 40px rgba(0,0,0,0.15);
      max-height: 80vh; overflow-y: auto; text-align: left; animation: fadeSlide 0.25s ease both;
    }
    .calendar-wrapper .modal-close { position: absolute; top: 12px; right: 14px; background: none; border: none; color: var(--text-dim); font-size: 1.4rem; cursor: pointer; }
    .calendar-wrapper .modal-close:hover { color: var(--red); }
    .calendar-wrapper .modal h2 { font-family: 'Playfair Display', 'Oswald', serif; font-weight: 700; font-size: 1.3rem; color: var(--navy); margin-bottom: 0.5rem; padding-right: 2rem; line-height: 1.3; text-transform: none; letter-spacing: 0; }
    .calendar-wrapper .modal .modal-org { display: inline-block; font-size: 0.75rem; padding: 3px 10px; border-radius: 12px; font-weight: 700; margin-bottom: 1rem; }
    .calendar-wrapper .modal .detail-row { display: flex; gap: 0.6rem; align-items: flex-start; margin-bottom: 0.6rem; font-size: 0.95rem; }
    .calendar-wrapper .modal .detail-row .icon { width: 20px; text-align: center; flex-shrink: 0; font-size: 0.95rem; margin-top: 1px; }
    .calendar-wrapper .modal .detail-row .detail-text { color: var(--text); }
    .calendar-wrapper .modal .detail-row .detail-text a { color: var(--red); text-decoration: underline; text-underline-offset: 2px; }
    .calendar-wrapper .modal .detail-row .detail-text a:hover { color: var(--navy); }
    .calendar-wrapper .modal-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.5rem; }
    .calendar-wrapper .modal-actions a { display: inline-block; padding: 9px 18px; border-radius: 6px; font-size: 0.8rem; font-weight: 700; text-decoration: none; transition: all 0.2s; text-transform: uppercase; letter-spacing: 0.04em; }
    .calendar-wrapper .modal-actions .btn-primary { background: var(--red); color: var(--white); }
    .calendar-wrapper .modal-actions .btn-primary:hover { background: #991b1b; }
    .calendar-wrapper .modal-actions .btn-secondary { background: var(--cream); border: 1px solid var(--border); color: var(--navy); }
    .calendar-wrapper .modal-actions .btn-secondary:hover { background: var(--navy); color: var(--white); border-color: var(--navy); }

    /* Submit Form */
    .calendar-wrapper .submit-event-section {
      max-width: 700px; margin: 3rem auto 0; background: var(--white); padding: 2rem;
      border-radius: 12px; border: 1px solid var(--border); box-shadow: var(--shadow);
    }
