    // ═══════════════════════════════════════════
    // COUNTY CONFIG
    // ═══════════════════════════════════════════
    const COUNTIES = {
      bastrop: { label: "Bastrop County", color: "#bf2d2d" },
      hays: { label: "Hays County", color: "#2d6abf" },
      fayette: { label: "Fayette County", color: "#7b2dbf" },
      travis: { label: "Travis County", color: "#bf6f2d" },
      williamson: { label: "Williamson County", color: "#2d8f5c" },
      fredericksburg: { label: "Fredericksburg Tea Party", color: "#bf2d7b" },
      statewide: { label: "Statewide / RPT", color: "#c9a84c" },
      burleson: { label: "Burleson County", color: "#4a90bf" },
      cacrc: { label: "CACRC", color: "#6b8f2d" },
      wtp: { label: "We The People LT", color: "#2dbfa0" },
      gawtp: { label: "Grassroots America", color: "#a05c2d" },
    };

    // ═══════════════════════════════════════════
    // STATE
    // ═══════════════════════════════════════════
    let currentDate = new Date(2026, 2, 1); // March 2026
    let currentView = 'list';
    let activeFilters = new Set(Object.keys(COUNTIES));
    let activeTypeFilters = new Set(['political', 'community']);

    const EVENT_TYPES = {
      political: { label: 'Political', color: '#991b1b' },
      community: { label: 'Community', color: '#1b5e20' },
    };

    const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const DAYS_SHORT = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

    // ═══════════════════════════════════════════
    // INITIALIZE
    // ═══════════════════════════════════════════
    function init() {
      buildFilters();
      // Force list view on mobile
      if (window.innerWidth <= 700) {
        currentView = 'list';
        document.getElementById('btnList').classList.add('active');
        document.getElementById('btnCalendar').classList.remove('active');
      }
      render();
      document.getElementById('prevMonth').addEventListener('click', () => { currentDate.setMonth(currentDate.getMonth() - 1); render(); });
      document.getElementById('nextMonth').addEventListener('click', () => { currentDate.setMonth(currentDate.getMonth() + 1); render(); });
      document.getElementById('modalOverlay').addEventListener('click', (e) => { if (e.target === e.currentTarget) closeModal(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
      
      // Filter toggle for mobile
      const filterToggleBtn = document.getElementById('filterToggleBtn');
      if (filterToggleBtn) {
        filterToggleBtn.addEventListener('click', () => {
          const section = document.getElementById('filterSection');
          const isExpanded = filterToggleBtn.getAttribute('aria-expanded') === 'true';
          filterToggleBtn.setAttribute('aria-expanded', !isExpanded);
          section.classList.toggle('collapsed-mobile', isExpanded);
          section.classList.toggle('expanded-mobile', !isExpanded);
        });
      }
    }

    // Attach to DOMContentLoaded to ensure elements exist when script runs in Astro
    document.addEventListener('DOMContentLoaded', init);

    // Legend removed — filter pills serve as both legend and filter

    function buildFilters() {
      // Build type filter pills
      const typePills = document.getElementById('typePills');
      if (typePills) {
        typePills.innerHTML = `<button class="type-pill active" data-type-filter="all">All Types</button>` +
          Object.entries(EVENT_TYPES).map(([key, val]) =>
            `<button class="type-pill active" data-type-filter="${key}"><span class="pill-dot" style="background:${val.color}"></span>${val.label}</button>`
          ).join('');
        typePills.querySelectorAll('.type-pill').forEach(btn => {
          btn.addEventListener('click', () => toggleTypeFilter(btn));
        });
      }

      // Build county filter pills
      const pills = document.getElementById('filterPills');
      if (!pills) return;
      pills.innerHTML = `<button class="filter-pill active" data-filter="all">All</button>` +
        Object.entries(COUNTIES).map(([key, val]) =>
          `<button class="filter-pill active" data-filter="${key}"><span class="pill-dot" style="background:${val.color}"></span>${val.label}</button>`
        ).join('');

      pills.querySelectorAll('.filter-pill').forEach(btn => {
        btn.addEventListener('click', () => toggleFilter(btn));
      });
    }

    window.toggleFilter = function(btn) {
      const filter = btn.dataset.filter;
      if (filter === 'all') {
        activeFilters = new Set(Object.keys(COUNTIES));
        document.querySelectorAll('.filter-pill').forEach(p => p.classList.add('active'));
      } else {
        const allBtn = document.querySelector('[data-filter="all"]');
        if (activeFilters.has(filter)) {
          activeFilters.delete(filter);
          btn.classList.remove('active');
        } else {
          activeFilters.add(filter);
          btn.classList.add('active');
        }
        allBtn.classList.toggle('active', activeFilters.size === Object.keys(COUNTIES).length);
      }
      render();
    };

    window.toggleTypeFilter = function(btn) {
      const filter = btn.dataset.typeFilter;
      if (filter === 'all') {
        activeTypeFilters = new Set(['political', 'community']);
        document.querySelectorAll('.type-pill').forEach(p => p.classList.add('active'));
      } else {
        const allBtn = document.querySelector('[data-type-filter="all"]');
        if (activeTypeFilters.has(filter)) {
          activeTypeFilters.delete(filter);
          btn.classList.remove('active');
        } else {
          activeTypeFilters.add(filter);
          btn.classList.add('active');
        }
        allBtn.classList.toggle('active', activeTypeFilters.size === Object.keys(EVENT_TYPES).length);
      }
      render();
    };

    window.setView = function(view) {
      currentView = view;
      document.getElementById('btnCalendar').classList.toggle('active', view === 'calendar');
      document.getElementById('btnList').classList.toggle('active', view === 'list');
      render();
    };

    // ═══════════════════════════════════════════
    // RENDER
    // ═══════════════════════════════════════════
    function render() {
      const year = currentDate.getFullYear();
      const month = currentDate.getMonth();
      document.getElementById('currentMonth').textContent = `${MONTHS[month]} ${year}`;

      const calWrap = document.getElementById('calGridWrap');
      const listView = document.getElementById('listView');

      if (currentView === 'calendar') {
        calWrap.classList.remove('hidden');
        listView.classList.remove('active');
        renderCalendar(year, month);
      } else {
        calWrap.classList.add('hidden');
        listView.classList.add('active');
        renderList(year, month);
      }
    }

    function getFilteredEvents() {
      return EVENTS.filter(e => activeFilters.has(e.county) && activeTypeFilters.has(e.type));
    }

    function renderCalendar(year, month) {
      const grid = document.getElementById('calGrid');
      const firstDay = new Date(year, month, 1).getDay();
      const daysInMonth = new Date(year, month + 1, 0).getDate();
      const daysInPrev = new Date(year, month, 0).getDate();
      const today = new Date();

      let html = DAYS_SHORT.map(d => `<div class="cal-header">${d}</div>`).join('');

      const filtered = getFilteredEvents();
      const eventsByDate = {};
      filtered.forEach(e => {
        if (!eventsByDate[e.date]) eventsByDate[e.date] = [];
        eventsByDate[e.date].push(e);
      });

      // Previous month days
      for (let i = firstDay - 1; i >= 0; i--) {
        const d = daysInPrev - i;
        html += `<div class="cal-day other-month"><span class="day-num">${d}</span></div>`;
      }

      // Current month days
      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = `${year}-${String(month + 1).padStart(2, '0')}-${String(d).padStart(2, '0')}`;
        const isToday = today.getFullYear() === year && today.getMonth() === month && today.getDate() === d;
        const dayEvents = eventsByDate[dateStr] || [];
        const hasEvents = dayEvents.length > 0;

        html += `<div class="cal-day${isToday ? ' today' : ''}${hasEvents ? ' has-events' : ''}">`;
        html += `<span class="day-num">${d}</span>`;

        const maxShow = 3;
        dayEvents.slice(0, maxShow).forEach((ev, i) => {
          html += `<div class="cal-event county-${ev.county}" onclick="openModal(${EVENTS.indexOf(ev)})" title="${ev.title}">${ev.title}</div>`;
        });
        if (dayEvents.length > maxShow) {
          html += `<div class="cal-more" onclick="showDayEvents('${dateStr}')">+${dayEvents.length - maxShow} more</div>`;
        }
        html += `</div>`;
      }

      // Next month days
      const totalCells = firstDay + daysInMonth;
      const remaining = (7 - (totalCells % 7)) % 7;
      for (let i = 1; i <= remaining; i++) {
        html += `<div class="cal-day other-month"><span class="day-num">${i}</span></div>`;
      }

      grid.innerHTML = html;
    }

    function renderList(year, month) {
      const listView = document.getElementById('listView');
      const filtered = getFilteredEvents()
        .filter(e => {
          const d = new Date(e.date + 'T00:00:00');
          return d.getFullYear() === year && d.getMonth() === month;
        })
        .sort((a, b) => a.date.localeCompare(b.date));

      if (filtered.length === 0) {
        listView.innerHTML = `<div style="text-align:center;padding:3rem;color:var(--text-dim);">
          <p style="font-size:1.1rem;margin-bottom:0.5rem;">No events this month</p>
          <p style="font-size:0.85rem;">Try a different month or adjust your filters.</p>
        </div>`;
        return;
      }

      let html = `<div class="list-month-group"><div class="list-month-label">${MONTHS[month]} ${year}</div>`;
      filtered.forEach((ev, i) => {
        const d = new Date(ev.date + 'T00:00:00');
        const countyConf = COUNTIES[ev.county];
        const idx = EVENTS.indexOf(ev);
        html += `
          <div class="list-event" onclick="openModal(${idx})" style="animation-delay:${i * 0.04}s">
            <div class="list-date">
              <div class="weekday">${DAYS_SHORT[d.getDay()]}</div>
              <div class="day">${d.getDate()}</div>
            </div>
            <div class="list-info">
              <span class="org-badge" style="background:${countyConf.color};color:${ev.county === 'statewide' || ev.county === 'wtp' ? 'var(--navy)' : '#fff'}">${ev.orgShort}</span>
              <span class="type-badge ${ev.type}">${ev.type === 'political' ? '★ Political' : '⌂ Community'}</span>
              <h3>${ev.title}</h3>
              <div class="time-loc">
                <strong>${ev.time}</strong>${ev.location ? ` · ${ev.location.split(',')[0]}` : ''}
              </div>
            </div>
          </div>`;
      });
      html += `</div>`;
      listView.innerHTML = html;
    }

    // ═══════════════════════════════════════════
    // MODAL
    // ═══════════════════════════════════════════
    window.openModal = function(idx) {
      const ev = EVENTS[idx];
      const d = new Date(ev.date + 'T00:00:00');
      const countyConf = COUNTIES[ev.county];
      const dateStr = `${DAYS_SHORT[d.getDay()]}, ${MONTHS[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}`;

      // Google Calendar link
      const gcalDate = ev.date.replace(/-/g, '');
      const gcalUrl = `https://www.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(ev.title)}&dates=${gcalDate}/${gcalDate}&details=${encodeURIComponent(ev.desc || '')}&location=${encodeURIComponent(ev.location || '')}`;

      const modal = document.getElementById('modal');
      modal.innerHTML = `
        <button class="modal-close" onclick="closeModal()">✕</button>
        <h2>${ev.title}</h2>
        <span class="modal-org" style="background:${countyConf.color};color:${ev.county === 'statewide' || ev.county === 'wtp' ? 'var(--navy)' : '#fff'}">${ev.org}</span>
        <span class="type-badge ${ev.type}" style="display:inline-block;margin-left:6px;font-size:0.7rem;padding:3px 10px;border-radius:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;${ev.type === 'political' ? 'background:#fde8e8;color:#991b1b;' : 'background:#e8f5e9;color:#1b5e20;'}">${ev.type === 'political' ? '★ Political' : '⌂ Community'}</span>
        <div class="detail-row"><span class="icon">📅</span><span class="detail-text">${dateStr}</span></div>
        <div class="detail-row"><span class="icon">🕐</span><span class="detail-text">${ev.time}${ev.endTime ? ' – ' + ev.endTime : ''}</span></div>
        ${ev.location ? `<div class="detail-row"><span class="icon">📍</span><span class="detail-text">${ev.location}</span></div>` : ''}
        ${ev.desc ? `<div class="detail-row"><span class="icon">📋</span><span class="detail-text">${ev.desc}</span></div>` : ''}
        <div class="modal-actions">
          ${ev.url ? `<a href="${ev.url}" target="_blank" class="btn-primary">Visit Website →</a>` : ''}
          <a href="${gcalUrl}" target="_blank" class="btn-secondary">+ Google Calendar</a>
        </div>
      `;
      document.getElementById('modalOverlay').classList.add('show');
    };

    window.closeModal = function() {
      document.getElementById('modalOverlay').classList.remove('show');
    };

    window.showDayEvents = function(dateStr) {
      // Jump to list view for that day
      const d = new Date(dateStr + 'T00:00:00');
      currentDate = new Date(d.getFullYear(), d.getMonth(), 1);
      setView('list');
    };
  </script>
</PageLayout>
