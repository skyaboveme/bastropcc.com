      { title:"Annual Book & Plant Sale", date:"2026-04-25", time:"9:00 AM - 4:00 PM", location:"Bastrop Public Library", type:"community", org:"Friends of the Library", desc:"Annual book and plant sale. Two-day event.", url:"https://www.visitbastrop.com/events/" },
      { title:"Annual Book & Plant Sale", date:"2026-04-26", time:"9:00 AM - 2:00 PM", location:"Bastrop Public Library", type:"community", org:"Friends of the Library", desc:"Day 2 of the annual book and plant sale.", url:"https://www.visitbastrop.com/events/" },
