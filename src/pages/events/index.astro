    let EVENTS = [...SEED_EVENTS];
    const EVENT_TYPES = { political: { label: 'Political', color: '#991b1b' }, community: { label: 'Community', color: '#059669' } };
    const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const DAYS_SHORT = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

    let currentDate = new Date(new Date().getFullYear(), new Date().getMonth(), 1);
    let currentView = 'upcoming';
    const UPCOMING_DAYS = 60;
    let activeTypeFilters = new Set(['political', 'community']);
    let activeOrgFilters = new Set();
    let knownOrgs = [];
    let orgFiltersInitialized = false;
    let searchQuery = '';
    let searchTokens = [];

    async function loadAPIEvents() {
      try {
        const res = await fetch('https://bastropcc-api.communications-b08.workers.dev/api/v1/public/events');
        const data = await res.json();
        if (data.success && data.data) {
          const apiEvents = data.data.map(ev => ({ ...ev, url: ev.event_url, desc: ev.description }));
          const existingKeys = new Set(EVENTS.map(e => e.title + '|' + e.date));
          apiEvents.forEach(ev => { if (!existingKeys.has(ev.title + '|' + ev.date)) EVENTS.push(ev); });
        }
      } catch (err) { console.error('API fetch error:', err); }
    }

    function init() {
      buildTypeFilters();
      buildOrgFilters();
      loadAPIEvents().then(() => { buildOrgFilters(); render(); });
      render(); // render seeds immediately
      document.getElementById('prevMonth').addEventListener('click', () => { currentDate.setMonth(currentDate.getMonth() - 1); render(); });
      document.getElementById('nextMonth').addEventListener('click', () => { currentDate.setMonth(currentDate.getMonth() + 1); render(); });
      document.getElementById('modalOverlay').addEventListener('click', (e) => { if (e.target === e.currentTarget) closeModal(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
      const orgToggle = document.getElementById('orgToggle');
      if (orgToggle) orgToggle.addEventListener('click', toggleOrgPillsExpanded);
      const searchInput = document.getElementById('eventSearch');
      const searchClear = document.getElementById('searchClear');
      if (searchInput) {
        searchInput.addEventListener('input', onSearchInput);
        searchInput.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && searchInput.value) { e.stopPropagation(); clearSearch(); }
        });
      }
      if (searchClear) searchClear.addEventListener('click', clearSearch);
    }
    document.addEventListener('DOMContentLoaded', init);

    function toggleOrgPillsExpanded() {
      const pills = document.getElementById('orgPills');
      const btn = document.getElementById('orgToggle');
      if (!pills || !btn) return;
      const expanded = pills.classList.toggle('expanded');
      btn.textContent = expanded ? 'Show less' : 'Show all';
      btn.setAttribute('aria-expanded', expanded ? 'true' : 'false');
    }

    let searchDebounceId = null;
    function onSearchInput(e) {
      const val = e.target.value;
      const clearBtn = document.getElementById('searchClear');
      if (clearBtn) clearBtn.hidden = !val;
      if (searchDebounceId) clearTimeout(searchDebounceId);
      searchDebounceId = setTimeout(() => {
        searchQuery = val.trim();
        searchTokens = searchQuery.toLowerCase().split(/\s+/).filter(Boolean);
        render();
      }, 120);
    }

    function clearSearch() {
      const input = document.getElementById('eventSearch');
      const clearBtn = document.getElementById('searchClear');
      if (input) input.value = '';
      if (clearBtn) clearBtn.hidden = true;
      searchQuery = '';
      searchTokens = [];
      render();
      if (input) input.focus();
    }

    function eventMatchesSearch(ev) {
      if (searchTokens.length === 0) return true;
      const haystack = (
        (ev.title || '') + ' ' +
        (ev.org || '') + ' ' +
        (ev.location || '') + ' ' +
        (ev.desc || '') + ' ' +
        (ev.type || '')
      ).toLowerCase();
      for (let i = 0; i < searchTokens.length; i++) {
        if (haystack.indexOf(searchTokens[i]) === -1) return false;
      }
      return true;
    }

    function updateSearchCount(count) {
      const el = document.getElementById('searchResultCount');
      if (!el) return;
      if (!searchQuery) { el.textContent = ''; el.classList.remove('has-query'); return; }
      el.classList.add('has-query');
      el.innerHTML = '<em>' + count + '</em> match' + (count === 1 ? '' : 'es');
    }

    function buildTypeFilters() {
      const typePills = document.getElementById('typePills');
      if (!typePills) return;
      typePills.innerHTML = '<button class="type-pill active" data-type-filter="all">All Events</button>' +
        Object.entries(EVENT_TYPES).map(([key, val]) =>
          '<button class="type-pill active" data-type-filter="' + key + '"><span class="pill-dot" style="background:' + val.color + '"></span>' + val.label + '</button>'
        ).join('');
      typePills.querySelectorAll('.type-pill').forEach(btn => btn.addEventListener('click', () => toggleTypeFilter(btn)));
    }

    window.toggleTypeFilter = function(btn) {
      const filter = btn.dataset.typeFilter;
      if (filter === 'all') {
        const allActive = activeTypeFilters.size === Object.keys(EVENT_TYPES).length;
        if (allActive) { activeTypeFilters.clear(); document.querySelectorAll('.type-pill').forEach(p => p.classList.remove('active')); }
        else { activeTypeFilters = new Set(Object.keys(EVENT_TYPES)); document.querySelectorAll('.type-pill').forEach(p => p.classList.add('active')); }
      } else {
        const allBtn = document.querySelector('[data-type-filter="all"]');
        if (activeTypeFilters.has(filter)) { activeTypeFilters.delete(filter); btn.classList.remove('active'); }
        else { activeTypeFilters.add(filter); btn.classList.add('active'); }
        allBtn.classList.toggle('active', activeTypeFilters.size === Object.keys(EVENT_TYPES).length);
      }
      render();
    };

    function escapeAttr(s) {
      return String(s).replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }

    function buildOrgFilters() {
      const orgPills = document.getElementById('orgPills');
      if (!orgPills) return;
      const prevKnown = new Set(knownOrgs);
      const orgSet = new Set();
      EVENTS.forEach(e => { orgSet.add((e.org && String(e.org).trim()) || 'Other'); });
      knownOrgs = Array.from(orgSet).sort((a, b) => a.localeCompare(b));
      if (!orgFiltersInitialized) {
        activeOrgFilters = new Set(knownOrgs);
        orgFiltersInitialized = true;
      } else {
        // Auto-activate orgs we hadn't seen before so newly arrived API events aren't hidden.
        knownOrgs.forEach(o => { if (!prevKnown.has(o)) activeOrgFilters.add(o); });
      }
      const allActive = knownOrgs.every(o => activeOrgFilters.has(o));
      const html = '<button class="org-pill all-orgs' + (allActive ? ' active' : '') + '" data-org-filter="__all__">All Orgs</button>' +
        knownOrgs.map(org => {
          const active = activeOrgFilters.has(org);
          return '<button class="org-pill' + (active ? ' active' : '') + '" data-org-filter="' + escapeAttr(org) + '">' + escapeAttr(org) + '</button>';
        }).join('');
      orgPills.innerHTML = html;
      orgPills.querySelectorAll('.org-pill').forEach(btn => btn.addEventListener('click', () => toggleOrgFilter(btn)));
    }

    window.toggleOrgFilter = function(btn) {
      const filter = btn.dataset.orgFilter;
      if (filter === '__all__') {
        const allActive = knownOrgs.every(o => activeOrgFilters.has(o));
        if (allActive) {
          activeOrgFilters.clear();
          document.querySelectorAll('.org-pill').forEach(p => p.classList.remove('active'));
        } else {
          activeOrgFilters = new Set(knownOrgs);
          document.querySelectorAll('.org-pill').forEach(p => p.classList.add('active'));
        }
      } else {
        if (activeOrgFilters.has(filter)) { activeOrgFilters.delete(filter); btn.classList.remove('active'); }
        else { activeOrgFilters.add(filter); btn.classList.add('active'); }
        const allBtn = document.querySelector('[data-org-filter="__all__"]');
        if (allBtn) allBtn.classList.toggle('active', knownOrgs.every(o => activeOrgFilters.has(o)));
      }
      render();
    };

    window.setView = function(view) {
      currentView = view;
      document.getElementById('btnUpcoming').classList.toggle('active', view === 'upcoming');
      document.getElementById('btnCalendar').classList.toggle('active', view === 'calendar');
      const monthNav = document.getElementById('monthNav');
      const upcomingLabel = document.getElementById('upcomingLabel');
      if (view === 'calendar') {
        monthNav.classList.remove('hidden');
        upcomingLabel.classList.remove('show');
      } else {
        monthNav.classList.add('hidden');
        upcomingLabel.classList.add('show');
      }
      render();
    };

    function render() {
      updateSearchCount(getFilteredEvents().length);
      const calWrap = document.getElementById('calGridWrap'), listView = document.getElementById('listView');
      if (currentView === 'calendar') {
        const year = currentDate.getFullYear(), month = currentDate.getMonth();
        document.getElementById('currentMonth').textContent = MONTHS[month] + ' ' + year;
        calWrap.classList.remove('hidden'); listView.classList.remove('active');
        renderCalendar(year, month);
      } else {
        calWrap.classList.add('hidden'); listView.classList.add('active');
        renderUpcoming();
      }
    }

    function getFilteredEvents() {
      return EVENTS.filter(e => {
        if (!activeTypeFilters.has(e.type)) return false;
        const org = (e.org && String(e.org).trim()) || 'Other';
        if (!activeOrgFilters.has(org)) return false;
        return eventMatchesSearch(e);
      });
    }

    function renderCalendar(year, month) {
      const grid = document.getElementById('calGrid');
      const firstDay = new Date(year, month, 1).getDay();
      const daysInMonth = new Date(year, month + 1, 0).getDate();
      const daysInPrev = new Date(year, month, 0).getDate();
      const today = new Date();
      let html = DAYS_SHORT.map(d => '<div class="cal-header">' + d + '</div>').join('');
      const filtered = getFilteredEvents();
      const eventsByDate = {};
      filtered.forEach(e => { if (!eventsByDate[e.date]) eventsByDate[e.date] = []; eventsByDate[e.date].push(e); });
      for (let i = firstDay - 1; i >= 0; i--) html += '<div class="cal-day other-month"><span class="day-num">' + (daysInPrev - i) + '</span></div>';
      for (let d = 1; d <= daysInMonth; d++) {
        const dateStr = year + '-' + String(month + 1).padStart(2, '0') + '-' + String(d).padStart(2, '0');
        const isToday = today.getFullYear() === year && today.getMonth() === month && today.getDate() === d;
        const dayEvents = eventsByDate[dateStr] || [];
        html += '<div class="cal-day' + (isToday ? ' today' : '') + (dayEvents.length ? ' has-events' : '') + '">';
        html += '<span class="day-num">' + d + '</span>';
        dayEvents.slice(0, 3).forEach(ev => { html += '<div class="cal-event type-' + ev.type + '" onclick="openModal(' + EVENTS.indexOf(ev) + ')" title="' + ev.title + '">' + ev.title + '</div>'; });
        if (dayEvents.length > 3) html += '<div class="cal-more" onclick="showDayEvents(\'' + dateStr + '\')">+' + (dayEvents.length - 3) + ' more</div>';
        html += '</div>';
      }
      const totalCells = firstDay + daysInMonth, remaining = (7 - (totalCells % 7)) % 7;
      for (let i = 1; i <= remaining; i++) html += '<div class="cal-day other-month"><span class="day-num">' + i + '</span></div>';
      grid.innerHTML = html;
    }

    function renderUpcoming() {
      const listView = document.getElementById('listView');
      const today = new Date(); today.setHours(0, 0, 0, 0);
      const endDate = new Date(today); endDate.setDate(endDate.getDate() + UPCOMING_DAYS);
      const filtered = getFilteredEvents().filter(e => {
        const d = new Date(e.date + 'T00:00:00');
        return Number.isFinite(d.valueOf()) && d >= today && d <= endDate;
      }).sort((a, b) => a.date.localeCompare(b.date));
      if (filtered.length === 0) {
        const headline = searchQuery
          ? 'No upcoming events match "' + searchQuery.replace(/</g, '&lt;') + '"'
          : 'No events in the next ' + UPCOMING_DAYS + ' days';
        const sub = searchQuery
          ? 'Try a shorter or different search term, clear filters, or switch to Month view to browse further out.'
          : 'Try adjusting your filters or switch to Month view to browse further out.';
        listView.innerHTML = '<div style="text-align:center;padding:3rem;color:var(--text-dim);"><p style="font-size:1.1rem;margin-bottom:0.5rem;">' + headline + '</p><p style="font-size:0.85rem;">' + sub + '</p></div>';
        return;
      }
      const groups = new Map();
      filtered.forEach(ev => {
        const d = new Date(ev.date + 'T00:00:00');
        const key = d.getFullYear() + '-' + d.getMonth();
        if (!groups.has(key)) groups.set(key, { year: d.getFullYear(), month: d.getMonth(), events: [] });
        groups.get(key).events.push(ev);
      });
      let html = '';
      let i = 0;
      groups.forEach(group => {
        html += '<div class="list-month-group"><div class="list-month-label">' + MONTHS[group.month] + ' ' + group.year + '</div>';
        group.events.forEach(ev => {
          const d = new Date(ev.date + 'T00:00:00');
          const typeConf = EVENT_TYPES[ev.type] || EVENT_TYPES.community;
          html += '<div class="list-event" onclick="openModal(' + EVENTS.indexOf(ev) + ')" style="animation-delay:' + (i * 0.03) + 's">' +
            '<div class="list-date"><div class="weekday">' + DAYS_SHORT[d.getDay()] + '</div><div class="day">' + d.getDate() + '</div></div>' +
            '<div class="list-info">' +
            '<span class="org-badge" style="background:' + typeConf.color + ';color:#fff">' + (ev.org || ev.type) + '</span>' +
            '<span class="type-badge ' + ev.type + '">' + (ev.type === 'political' ? '★ Political' : '⌂ Community') + '</span>' +
            '<h3>' + ev.title + '</h3>' +
            '<div class="time-loc"><strong>' + ev.time + '</strong>' + (ev.location ? ' · ' + ev.location.split(',')[0] : '') + '</div>' +
            '</div></div>';
          i++;
        });
        html += '</div>';
      });
      listView.innerHTML = html;
    }

    function parseAmPm(str) {
      const m = String(str || '').trim().match(/^(\d{1,2})(?::(\d{2}))?\s*(am|pm|noon|midnight)?/i);
      if (!m) return null;
      let h = parseInt(m[1], 10);
      const min = parseInt(m[2] || '0', 10);
      const suffix = (m[3] || '').toLowerCase();
      if (suffix === 'noon') return [12, 0];
      if (suffix === 'midnight') return [0, 0];
      if (suffix === 'pm' && h < 12) h += 12;
      if (suffix === 'am' && h === 12) h = 0;
      return [h, min];
    }

    function pad2(n) { return String(n).padStart(2, '0'); }

    function fmtGcalDateTime(d) {
      return d.getFullYear() + pad2(d.getMonth() + 1) + pad2(d.getDate()) + 'T' + pad2(d.getHours()) + pad2(d.getMinutes()) + '00';
    }
    function fmtGcalDate(d) {
      return d.getFullYear() + pad2(d.getMonth() + 1) + pad2(d.getDate());
    }

    function buildEventTimes(ev) {
      const baseDate = new Date(ev.date + 'T00:00:00');
      const t = String(ev.time || '').trim();
      const isAllDayLike = !t || /^all\s*day$/i.test(t) || /^tbd$/i.test(t);
      if (isAllDayLike) {
        const next = new Date(baseDate); next.setDate(baseDate.getDate() + 1);
        return { allDay: true, startStr: fmtGcalDate(baseDate), endStr: fmtGcalDate(next) };
      }
      const parts = t.split(/\s*[-\u2013\u2014]\s*/);
      const start = parseAmPm(parts[0]);
      if (!start) {
        const next = new Date(baseDate); next.setDate(baseDate.getDate() + 1);
        return { allDay: true, startStr: fmtGcalDate(baseDate), endStr: fmtGcalDate(next) };
      }
      let end = parts[1] ? parseAmPm(parts[1]) : null;
      if (!end && ev.endTime) end = parseAmPm(ev.endTime);
      const startDt = new Date(baseDate.getFullYear(), baseDate.getMonth(), baseDate.getDate(), start[0], start[1], 0);
      const endDt = end
        ? new Date(baseDate.getFullYear(), baseDate.getMonth(), baseDate.getDate(), end[0], end[1], 0)
        : new Date(startDt.getTime() + 60 * 60 * 1000);
      if (endDt <= startDt) endDt.setDate(endDt.getDate() + 1);
      return { allDay: false, startStr: fmtGcalDateTime(startDt), endStr: fmtGcalDateTime(endDt), tz: 'America/Chicago' };
    }

    function buildGcalUrl(ev) {
      const t = buildEventTimes(ev);
      let url = 'https://www.google.com/calendar/render?action=TEMPLATE' +
        '&text=' + encodeURIComponent(ev.title) +
        '&dates=' + t.startStr + '/' + t.endStr +
        '&details=' + encodeURIComponent(ev.desc || '') +
        '&location=' + encodeURIComponent(ev.location || '');
      if (!t.allDay && t.tz) url += '&ctz=' + encodeURIComponent(t.tz);
      return url;
    }

    function escIcs(text) {
      return String(text || '').replace(/\\/g, '\\\\').replace(/;/g, '\\;').replace(/,/g, '\\,').replace(/\r?\n/g, '\\n');
    }
    function foldIcsLine(line) {
      if (line.length <= 75) return line;
      let out = line.slice(0, 75); let rest = line.slice(75);
      while (rest.length > 0) { out += '\r\n ' + rest.slice(0, 74); rest = rest.slice(74); }
      return out;
    }
    function nowUtcStamp() {
      const d = new Date();
      return d.getUTCFullYear() + pad2(d.getUTCMonth() + 1) + pad2(d.getUTCDate()) + 'T' +
        pad2(d.getUTCHours()) + pad2(d.getUTCMinutes()) + pad2(d.getUTCSeconds()) + 'Z';
    }
    function slugify(s) {
      return String(s || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 50);
    }

    const VTIMEZONE_CHICAGO_LINES = [
      'BEGIN:VTIMEZONE',
      'TZID:America/Chicago',
      'BEGIN:DAYLIGHT',
      'DTSTART:20070311T020000',
      'RRULE:FREQ=YEARLY;BYMONTH=3;BYDAY=2SU',
      'TZNAME:CDT',
      'TZOFFSETFROM:-0600',
      'TZOFFSETTO:-0500',
      'END:DAYLIGHT',
      'BEGIN:STANDARD',
      'DTSTART:20071104T020000',
      'RRULE:FREQ=YEARLY;BYMONTH=11;BYDAY=1SU',
      'TZNAME:CST',
      'TZOFFSETFROM:-0500',
      'TZOFFSETTO:-0600',
      'END:STANDARD',
      'END:VTIMEZONE'
    ];

    function buildIcsContent(ev) {
      const t = buildEventTimes(ev);
      const uid = ev.date.replace(/-/g, '') + '-' + slugify(ev.title) + '@bastropcc.com';
      const lines = [
        'BEGIN:VCALENDAR',
        'VERSION:2.0',
        'PRODID:-//Bastrop County Conservatives//Events//EN',
        'CALSCALE:GREGORIAN',
        'METHOD:PUBLISH'
      ];
      if (!t.allDay) VTIMEZONE_CHICAGO_LINES.forEach(function(l) { lines.push(l); });
      lines.push('BEGIN:VEVENT');
      lines.push('UID:' + uid);
      lines.push('DTSTAMP:' + nowUtcStamp());
      if (t.allDay) {
        lines.push('DTSTART;VALUE=DATE:' + t.startStr);
        lines.push('DTEND;VALUE=DATE:' + t.endStr);
      } else {
        lines.push('DTSTART;TZID=America/Chicago:' + t.startStr);
        lines.push('DTEND;TZID=America/Chicago:' + t.endStr);
      }
      lines.push('SUMMARY:' + escIcs(ev.title));
      if (ev.desc) lines.push('DESCRIPTION:' + escIcs(ev.desc));
      if (ev.location) lines.push('LOCATION:' + escIcs(ev.location));
      if (ev.url) lines.push('URL:' + ev.url);
      lines.push('END:VEVENT');
      lines.push('END:VCALENDAR');
      return lines.map(foldIcsLine).join('\r\n');
    }

    window.downloadIcs = function(idx) {
      const ev = EVENTS[idx]; if (!ev) return;
      const ics = buildIcsContent(ev);
      const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = (ev.date + '-' + slugify(ev.title)) + '.ics';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      setTimeout(function() { URL.revokeObjectURL(url); }, 1000);
    };

    window.openModal = function(idx) {
      const ev = EVENTS[idx]; if (!ev) return;
      const d = new Date(ev.date + 'T00:00:00');
      const typeConf = EVENT_TYPES[ev.type] || EVENT_TYPES.community;
      const dateStr = DAYS_SHORT[d.getDay()] + ', ' + MONTHS[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear();
      const gcalUrl = buildGcalUrl(ev);
      document.getElementById('modal').innerHTML =
        '<button class="modal-close" onclick="closeModal()">✕</button>' +
        '<h2>' + ev.title + '</h2>' +
        '<span class="modal-org" style="background:' + typeConf.color + ';color:#fff">' + (ev.org || ev.type) + '</span>' +
        '<span class="type-badge ' + ev.type + '" style="display:inline-block;margin-left:6px;font-size:0.7rem;padding:3px 10px;border-radius:10px;font-weight:700;text-transform:uppercase;letter-spacing:0.04em;' + (ev.type === 'political' ? 'background:#fde8e8;color:#991b1b;' : 'background:#e8f5e9;color:#1b5e20;') + '">' + (ev.type === 'political' ? '★ Political' : '⌂ Community') + '</span>' +
        '<div class="detail-row"><span class="icon">📅</span><span class="detail-text">' + dateStr + '</span></div>' +
        '<div class="detail-row"><span class="icon">🕐</span><span class="detail-text">' + ev.time + '</span></div>' +
        (ev.location ? '<div class="detail-row"><span class="icon">📍</span><span class="detail-text">' + ev.location + '</span></div>' : '') +
        (ev.desc ? '<div class="detail-row"><span class="icon">📋</span><span class="detail-text">' + ev.desc + '</span></div>' : '') +
        '<div class="modal-actions">' +
        (ev.url ? '<a href="' + ev.url + '" target="_blank" class="btn-primary">Visit Website →</a>' : '') +
        '<a href="' + gcalUrl + '" target="_blank" class="btn-secondary">+ Google</a>' +
        '<a href="javascript:void(0)" onclick="downloadIcs(' + idx + ')" class="btn-secondary">+ Apple/Outlook (.ics)</a>' +
        '</div>';
      document.getElementById('modalOverlay').classList.add('show');
    };
    window.closeModal = function() { document.getElementById('modalOverlay').classList.remove('show'); };
    window.showDayEvents = function(dateStr) { const d = new Date(dateStr + 'T00:00:00'); currentDate = new Date(d.getFullYear(), d.getMonth(), 1); setView('upcoming'); };
  </script>

  <div class="not-prose max-w-3xl mx-auto mt-10">
    <div class="bg-bcc-cream border border-bcc-gray-200 rounded-2xl p-6">
      <p class="text-bcc-gray-700 leading-relaxed">
        This page lists upcoming community and political events across Bastrop County and nearby communities. For citations, prefer linking directly to the event source (shown in each event) and include the date.
      </p>
      <p class="text-sm text-bcc-gray-500 mt-3 italic">
        Last updated: {LAST_UPDATED}
      </p>
    </div>
  </div>

  {upcoming.length > 0 && (
    <script type="application/ld+json" set:html={eventsSchema} />
  )}

</PageLayout>
