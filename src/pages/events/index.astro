    const EVENT_TYPES = {
      political: { label: 'Political', color: '#b91c1c', icon: '★' },
      community: { label: 'Community', color: '#059669', icon: '⌂' }
    };
    const MONTHS = ['January','February','March','April','May','June','July','August','September','October','November','December'];
    const MONTHS_SHORT = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const DAYS_SHORT = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];

    let EVENTS = [];
    let activeTypeFilters = new Set(['political', 'community']);
    let activeOrgFilters = new Set();
    let knownOrgs = [];
    let orgFiltersInitialized = false;
    let searchQuery = '';
    let searchTokens = [];
    let searchDebounceId = null;

    function eventKey(e) { return (e.title || '') + '|' + (e.date || ''); }

    function ingestEvents() {
      const merged = [];
      const seen = new Set();
      const push = (ev) => {
        const key = eventKey(ev);
        if (!ev.title || !ev.date || seen.has(key)) return;
        seen.add(key);
        merged.push({
          title: ev.title,
          date: ev.date,
          time: ev.time || '',
          endTime: ev.endTime || '',
          location: ev.location || '',
          type: ev.type === 'political' ? 'political' : 'community',
          org: (ev.org && String(ev.org).trim()) || 'Other',
          desc: ev.desc || ev.description || '',
          url: ev.url || ev.link || '',
          featured: ev.featured === true
        });
      };
      // Order: JSON files first (most curated), then SEED, then API.
      // Dedup keeps the first entry, so JSON wins over SEED for the same key.
      (Array.isArray(JSON_EVENTS_DATA) ? JSON_EVENTS_DATA : []).forEach(push);
      SEED_EVENTS.forEach(push);
      EVENTS = merged.sort((a, b) => a.date.localeCompare(b.date));
    }

    async function loadAPIEvents() {
      try {
        const res = await fetch('https://bastropcc-api.communications-b08.workers.dev/api/v1/public/events');
        const data = await res.json();
        if (!data || !data.success || !Array.isArray(data.data)) return;
        const seen = new Set(EVENTS.map(eventKey));
        data.data.forEach((ev) => {
          const norm = {
            title: ev.title,
            date: ev.date,
            time: ev.time || '',
            endTime: ev.endTime || '',
            location: ev.location || '',
            type: ev.type === 'political' ? 'political' : 'community',
            org: (ev.org && String(ev.org).trim()) || 'Other',
            desc: ev.description || ev.desc || '',
            url: ev.event_url || ev.url || '',
            featured: ev.featured === true
          };
          if (!norm.title || !norm.date) return;
          const k = eventKey(norm);
          if (!seen.has(k)) { seen.add(k); EVENTS.push(norm); }
        });
        EVENTS.sort((a, b) => a.date.localeCompare(b.date));
      } catch (err) { /* network failure silent */ }
    }

    function init() {
      ingestEvents();
      buildTypeChips();
      buildOrgChips();
      render();
      loadAPIEvents().then(() => { buildOrgChips(); render(); });
      const searchInput = document.getElementById('eventSearch');
      const searchClear = document.getElementById('searchClear');
      if (searchInput) {
        searchInput.addEventListener('input', onSearchInput);
        searchInput.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && searchInput.value) { e.stopPropagation(); clearSearch(); }
        });
      }
      if (searchClear) searchClear.addEventListener('click', clearSearch);
      const overlay = document.getElementById('modalOverlay');
      if (overlay) overlay.addEventListener('click', (e) => { if (e.target === e.currentTarget) closeModal(); });
      document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
    }

    function escapeAttr(s) {
      return String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/"/g, '&quot;').replace(/'/g, '&#39;')
        .replace(/</g, '&lt;').replace(/>/g, '&gt;');
    }
    function escHtml(s) { return escapeAttr(s); }

    function buildTypeChips() {
      const root = document.getElementById('typeChips');
      if (!root) return;
      let html = '<button type="button" class="chip all-chip active" data-type="__all__">All</button>';
      Object.entries(EVENT_TYPES).forEach(([key, val]) => {
        html += '<button type="button" class="chip active" data-type="' + key + '">' +
          '<span class="dot" style="background:' + val.color + '"></span>' + val.icon + ' ' + val.label +
          '</button>';
      });
      root.innerHTML = html;
      root.querySelectorAll('.chip').forEach((btn) => btn.addEventListener('click', () => toggleType(btn)));
    }

    function toggleType(btn) {
      const t = btn.dataset.type;
      if (t === '__all__') {
        const allActive = activeTypeFilters.size === Object.keys(EVENT_TYPES).length;
        if (allActive) { activeTypeFilters.clear(); document.querySelectorAll('#typeChips .chip').forEach((c) => c.classList.remove('active')); }
        else { activeTypeFilters = new Set(Object.keys(EVENT_TYPES)); document.querySelectorAll('#typeChips .chip').forEach((c) => c.classList.add('active')); }
      } else {
        if (activeTypeFilters.has(t)) { activeTypeFilters.delete(t); btn.classList.remove('active'); }
        else { activeTypeFilters.add(t); btn.classList.add('active'); }
        const allBtn = document.querySelector('#typeChips [data-type="__all__"]');
        if (allBtn) allBtn.classList.toggle('active', activeTypeFilters.size === Object.keys(EVENT_TYPES).length);
      }
      render();
    }

    function buildOrgChips() {
      const root = document.getElementById('orgChips');
      if (!root) return;
      const prevKnown = new Set(knownOrgs);
      const set = new Set();
      EVENTS.forEach((e) => set.add(e.org || 'Other'));
      knownOrgs = Array.from(set).sort((a, b) => a.localeCompare(b));
      if (!orgFiltersInitialized) { activeOrgFilters = new Set(knownOrgs); orgFiltersInitialized = true; }
      else { knownOrgs.forEach((o) => { if (!prevKnown.has(o)) activeOrgFilters.add(o); }); }
      const allActive = knownOrgs.every((o) => activeOrgFilters.has(o));
      let html = '<button type="button" class="chip all-chip' + (allActive ? ' active' : '') + '" data-org="__all__">All</button>';
      knownOrgs.forEach((o) => {
        const a = activeOrgFilters.has(o);
        html += '<button type="button" class="chip' + (a ? ' active' : '') + '" data-org="' + escapeAttr(o) + '">' + escHtml(o) + '</button>';
      });
      root.innerHTML = html;
      root.querySelectorAll('.chip').forEach((btn) => btn.addEventListener('click', () => toggleOrg(btn)));
    }

    function toggleOrg(btn) {
      const o = btn.dataset.org;
      if (o === '__all__') {
        const allActive = knownOrgs.every((x) => activeOrgFilters.has(x));
        if (allActive) { activeOrgFilters.clear(); document.querySelectorAll('#orgChips .chip').forEach((c) => c.classList.remove('active')); }
        else { activeOrgFilters = new Set(knownOrgs); document.querySelectorAll('#orgChips .chip').forEach((c) => c.classList.add('active')); }
      } else {
        if (activeOrgFilters.has(o)) { activeOrgFilters.delete(o); btn.classList.remove('active'); }
        else { activeOrgFilters.add(o); btn.classList.add('active'); }
        const allBtn = document.querySelector('#orgChips [data-org="__all__"]');
        if (allBtn) allBtn.classList.toggle('active', knownOrgs.every((x) => activeOrgFilters.has(x)));
      }
      render();
    }

    function onSearchInput(e) {
      const val = e.target.value;
      const clearBtn = document.getElementById('searchClear');
      if (clearBtn) clearBtn.hidden = !val;
      if (searchDebounceId) clearTimeout(searchDebounceId);
      searchDebounceId = setTimeout(() => {
        searchQuery = val.trim();
        searchTokens = searchQuery.toLowerCase().split(/\s+/).filter(Boolean);
        render();
      }, 120);
    }

    function clearSearch() {
      const input = document.getElementById('eventSearch');
      const clearBtn = document.getElementById('searchClear');
      if (input) input.value = '';
      if (clearBtn) clearBtn.hidden = true;
      searchQuery = ''; searchTokens = [];
      render();
      if (input) input.focus();
    }

    function eventMatchesSearch(ev) {
      if (searchTokens.length === 0) return true;
      const hay = ((ev.title || '') + ' ' + (ev.org || '') + ' ' + (ev.location || '') + ' ' + (ev.desc || '') + ' ' + (ev.type || '')).toLowerCase();
      for (let i = 0; i < searchTokens.length; i++) {
        if (hay.indexOf(searchTokens[i]) === -1) return false;
      }
      return true;
    }

    function getFilteredEvents() {
      return EVENTS.filter((e) => {
        if (!activeTypeFilters.has(e.type)) return false;
        if (!activeOrgFilters.has(e.org || 'Other')) return false;
        return eventMatchesSearch(e);
      });
    }

    function getUpcoming(filteredOnly) {
      const today = new Date(); today.setHours(0,0,0,0);
      const list = filteredOnly ? getFilteredEvents() : EVENTS;
      return list.filter((e) => {
        const d = new Date(e.date + 'T00:00:00');
        return Number.isFinite(d.valueOf()) && d >= today;
      });
    }

    function pickHero() {
      const all = getUpcoming(false);
      const featured = all.find((e) => e.featured);
      return featured || all[0] || null;
    }

    function updateResultCount(count) {
      const el = document.getElementById('resultCount');
      if (!el) return;
      if (!searchQuery) { el.textContent = ''; el.classList.remove('has-query'); return; }
      el.classList.add('has-query');
      el.innerHTML = '<em>' + count + '</em> match' + (count === 1 ? '' : 'es');
    }

    function renderHero() {
      const root = document.getElementById('heroEvent');
      if (!root) return;
      const ev = pickHero();
      if (!ev) {
        root.innerHTML = '<div class="hero-tag">Upcoming</div><h2>No upcoming events scheduled</h2><p class="hero-where-when">Check back soon, or submit one below.</p>';
        return;
      }
      const idx = EVENTS.indexOf(ev);
      const d = new Date(ev.date + 'T00:00:00');
      const typeConf = EVENT_TYPES[ev.type] || EVENT_TYPES.community;
      const gcalUrl = buildGcalUrl(ev);
      const tagText = ev.featured ? 'Featured Event' : 'Next Up';
      root.innerHTML =
        '<div class="hero-tag">★ ' + tagText + '</div>' +
        '<div class="hero-grid">' +
          '<div class="hero-date">' +
            '<div class="h-month">' + MONTHS_SHORT[d.getMonth()] + '</div>' +
            '<div class="h-day">' + d.getDate() + '</div>' +
            '<div class="h-weekday">' + DAYS_SHORT[d.getDay()] + '</div>' +
          '</div>' +
          '<div class="hero-body">' +
            '<div class="hero-meta">' +
              '<span class="badge org">' + escHtml(ev.org) + '</span>' +
              '<span class="badge ' + ev.type + '">' + typeConf.icon + ' ' + typeConf.label + '</span>' +
            '</div>' +
            '<h2>' + escHtml(ev.title) + '</h2>' +
            '<div class="hero-where-when"><strong>' + escHtml(ev.time || 'TBA') + '</strong>' + (ev.location ? ' · ' + escHtml(ev.location) : '') + '</div>' +
            (ev.desc ? '<p class="hero-desc">' + escHtml(ev.desc) + '</p>' : '') +
            '<div class="hero-actions">' +
              '<button type="button" class="btn-primary" onclick="openModal(' + idx + ')">Details &amp; Calendar Add →</button>' +
              (ev.url ? '<a href="' + escapeAttr(ev.url) + '" target="_blank" rel="noopener" class="btn-ghost">Visit Website</a>' : '') +
            '</div>' +
          '</div>' +
        '</div>';
    }

    function renderList() {
      const root = document.getElementById('eventList');
      if (!root) return;
      const filtered = getFilteredEvents();
      const upcoming = filtered.filter((e) => {
        const d = new Date(e.date + 'T00:00:00');
        const today = new Date(); today.setHours(0,0,0,0);
        return Number.isFinite(d.valueOf()) && d >= today;
      });
      updateResultCount(filtered.length);

      if (upcoming.length === 0) {
        const headline = searchQuery
          ? 'No upcoming events match "' + escHtml(searchQuery) + '"'
          : (filtered.length === 0 ? 'No events match your filters' : 'No upcoming events');
        const sub = searchQuery
          ? 'Try a different search term or clear your filters.'
          : 'Adjust your filters above, or submit an event using the form below.';
        root.innerHTML = '<div class="empty-state"><strong>' + headline + '</strong><span>' + sub + '</span></div>';
        return;
      }

      const groups = new Map();
      upcoming.forEach((ev) => {
        const d = new Date(ev.date + 'T00:00:00');
        const key = d.getFullYear() + '-' + d.getMonth();
        if (!groups.has(key)) groups.set(key, { year: d.getFullYear(), month: d.getMonth(), events: [] });
        groups.get(key).events.push(ev);
      });

      let html = '';
      let i = 0;
      groups.forEach((group) => {
        html += '<div class="month-divider"><span class="month-name">' + MONTHS[group.month] + ' ' + group.year + '</span><span class="month-line"></span></div>';
        group.events.forEach((ev) => {
          const d = new Date(ev.date + 'T00:00:00');
          const idx = EVENTS.indexOf(ev);
          const typeConf = EVENT_TYPES[ev.type] || EVENT_TYPES.community;
          html += '<button type="button" role="listitem" class="event-row is-' + ev.type + '" onclick="openModal(' + idx + ')" style="animation-delay:' + Math.min(i * 0.025, 0.4) + 's">' +
            '<div class="ev-date">' +
              '<div class="ev-weekday">' + DAYS_SHORT[d.getDay()] + '</div>' +
              '<div class="ev-day">' + d.getDate() + '</div>' +
              '<div class="ev-mon">' + MONTHS_SHORT[d.getMonth()] + '</div>' +
            '</div>' +
            '<div class="ev-body">' +
              '<div class="ev-meta">' +
                (ev.featured ? '<span class="badge featured">★ Featured</span>' : '') +
                '<span class="badge ' + ev.type + '">' + typeConf.icon + ' ' + typeConf.label + '</span>' +
                '<span class="badge org">' + escHtml(ev.org) + '</span>' +
              '</div>' +
              '<h3>' + escHtml(ev.title) + '</h3>' +
              '<div class="ev-where-when">' +
                '<span class="ev-time">' + escHtml(ev.time || 'TBA') + '</span>' +
                (ev.location ? '<span class="ev-loc">· ' + escHtml(ev.location.split(',')[0]) + '</span>' : '') +
              '</div>' +
            '</div>' +
          '</button>';
          i++;
        });
      });
      root.innerHTML = html;
    }

    function render() {
      renderHero();
      renderList();
    }

    // ─── Calendar export helpers (preserved from prior version) ───
    function parseAmPm(str) {
      const m = String(str || '').trim().match(/^(\d{1,2})(?::(\d{2}))?\s*(am|pm|noon|midnight)?/i);
      if (!m) return null;
      let h = parseInt(m[1], 10);
      const min = parseInt(m[2] || '0', 10);
      const suffix = (m[3] || '').toLowerCase();
      if (suffix === 'noon') return [12, 0];
      if (suffix === 'midnight') return [0, 0];
      if (suffix === 'pm' && h < 12) h += 12;
      if (suffix === 'am' && h === 12) h = 0;
      return [h, min];
    }
    function pad2(n) { return String(n).padStart(2, '0'); }
    function fmtGcalDateTime(d) {
      return d.getFullYear() + pad2(d.getMonth() + 1) + pad2(d.getDate()) + 'T' + pad2(d.getHours()) + pad2(d.getMinutes()) + '00';
    }
    function fmtGcalDate(d) { return d.getFullYear() + pad2(d.getMonth() + 1) + pad2(d.getDate()); }
    function buildEventTimes(ev) {
      const baseDate = new Date(ev.date + 'T00:00:00');
      const t = String(ev.time || '').trim();
      const isAllDayLike = !t || /^all\s*day$/i.test(t) || /^tbd$/i.test(t) || /^tba$/i.test(t);
      if (isAllDayLike) {
        const next = new Date(baseDate); next.setDate(baseDate.getDate() + 1);
        return { allDay: true, startStr: fmtGcalDate(baseDate), endStr: fmtGcalDate(next) };
      }
      const parts = t.split(/\s*[-\u2013\u2014]\s*/);
      const start = parseAmPm(parts[0]);
      if (!start) {
        const next = new Date(baseDate); next.setDate(baseDate.getDate() + 1);
        return { allDay: true, startStr: fmtGcalDate(baseDate), endStr: fmtGcalDate(next) };
      }
      let end = parts[1] ? parseAmPm(parts[1]) : null;
      if (!end && ev.endTime) end = parseAmPm(ev.endTime);
      const startDt = new Date(baseDate.getFullYear(), baseDate.getMonth(), baseDate.getDate(), start[0], start[1], 0);
      const endDt = end
        ? new Date(baseDate.getFullYear(), baseDate.getMonth(), baseDate.getDate(), end[0], end[1], 0)
        : new Date(startDt.getTime() + 60 * 60 * 1000);
      if (endDt <= startDt) endDt.setDate(endDt.getDate() + 1);
      return { allDay: false, startStr: fmtGcalDateTime(startDt), endStr: fmtGcalDateTime(endDt), tz: 'America/Chicago' };
    }
    function buildGcalUrl(ev) {
      const t = buildEventTimes(ev);
      let url = 'https://www.google.com/calendar/render?action=TEMPLATE' +
        '&text=' + encodeURIComponent(ev.title) +
        '&dates=' + t.startStr + '/' + t.endStr +
        '&details=' + encodeURIComponent(ev.desc || '') +
        '&location=' + encodeURIComponent(ev.location || '');
      if (!t.allDay && t.tz) url += '&ctz=' + encodeURIComponent(t.tz);
      return url;
    }
    function escIcs(text) {
      return String(text || '').replace(/\\/g, '\\\\').replace(/;/g, '\\;').replace(/,/g, '\\,').replace(/\r?\n/g, '\\n');
    }
    function foldIcsLine(line) {
      if (line.length <= 75) return line;
      let out = line.slice(0, 75); let rest = line.slice(75);
      while (rest.length > 0) { out += '\r\n ' + rest.slice(0, 74); rest = rest.slice(74); }
      return out;
    }
    function nowUtcStamp() {
      const d = new Date();
      return d.getUTCFullYear() + pad2(d.getUTCMonth() + 1) + pad2(d.getUTCDate()) + 'T' +
        pad2(d.getUTCHours()) + pad2(d.getUTCMinutes()) + pad2(d.getUTCSeconds()) + 'Z';
    }
    function slugify(s) {
      return String(s || '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 50);
    }
    const VTIMEZONE_CHICAGO_LINES = [
      'BEGIN:VTIMEZONE','TZID:America/Chicago',
      'BEGIN:DAYLIGHT','DTSTART:20070311T020000','RRULE:FREQ=YEARLY;BYMONTH=3;BYDAY=2SU','TZNAME:CDT','TZOFFSETFROM:-0600','TZOFFSETTO:-0500','END:DAYLIGHT',
      'BEGIN:STANDARD','DTSTART:20071104T020000','RRULE:FREQ=YEARLY;BYMONTH=11;BYDAY=1SU','TZNAME:CST','TZOFFSETFROM:-0500','TZOFFSETTO:-0600','END:STANDARD',
      'END:VTIMEZONE'
    ];
    function buildIcsContent(ev) {
      const t = buildEventTimes(ev);
      const uid = ev.date.replace(/-/g, '') + '-' + slugify(ev.title) + '@bastropcc.com';
      const lines = [
        'BEGIN:VCALENDAR','VERSION:2.0','PRODID:-//Bastrop County Conservatives//Events//EN',
        'CALSCALE:GREGORIAN','METHOD:PUBLISH'
      ];
      if (!t.allDay) VTIMEZONE_CHICAGO_LINES.forEach((l) => lines.push(l));
      lines.push('BEGIN:VEVENT');
      lines.push('UID:' + uid);
      lines.push('DTSTAMP:' + nowUtcStamp());
      if (t.allDay) {
        lines.push('DTSTART;VALUE=DATE:' + t.startStr);
        lines.push('DTEND;VALUE=DATE:' + t.endStr);
      } else {
        lines.push('DTSTART;TZID=America/Chicago:' + t.startStr);
        lines.push('DTEND;TZID=America/Chicago:' + t.endStr);
      }
      lines.push('SUMMARY:' + escIcs(ev.title));
      if (ev.desc) lines.push('DESCRIPTION:' + escIcs(ev.desc));
      if (ev.location) lines.push('LOCATION:' + escIcs(ev.location));
      if (ev.url) lines.push('URL:' + ev.url);
      lines.push('END:VEVENT');
      lines.push('END:VCALENDAR');
      return lines.map(foldIcsLine).join('\r\n');
    }

    window.downloadIcs = function(idx) {
      const ev = EVENTS[idx]; if (!ev) return;
      const ics = buildIcsContent(ev);
      const blob = new Blob([ics], { type: 'text/calendar;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = (ev.date + '-' + slugify(ev.title)) + '.ics';
      document.body.appendChild(a); a.click(); document.body.removeChild(a);
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    };

    window.openModal = function(idx) {
      const ev = EVENTS[idx]; if (!ev) return;
      const d = new Date(ev.date + 'T00:00:00');
      const typeConf = EVENT_TYPES[ev.type] || EVENT_TYPES.community;
      const dateStr = DAYS_SHORT[d.getDay()] + ', ' + MONTHS[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear();
      const gcalUrl = buildGcalUrl(ev);
      document.getElementById('modal').innerHTML =
        '<button class="modal-close" onclick="closeModal()" aria-label="Close">✕</button>' +
        '<h2 id="modalTitle">' + escHtml(ev.title) + '</h2>' +
        '<div class="modal-meta">' +
          '<span class="badge org">' + escHtml(ev.org) + '</span>' +
          '<span class="badge ' + ev.type + '">' + typeConf.icon + ' ' + typeConf.label + '</span>' +
          (ev.featured ? '<span class="badge org" style="background:#c9a84c;color:#1a2b4a;border-color:#c9a84c">★ Featured</span>' : '') +
        '</div>' +
        '<div class="detail-row"><span class="icon">📅</span><span class="detail-text">' + dateStr + '</span></div>' +
        '<div class="detail-row"><span class="icon">🕐</span><span class="detail-text">' + escHtml(ev.time || 'Time TBA') + '</span></div>' +
        (ev.location ? '<div class="detail-row"><span class="icon">📍</span><span class="detail-text">' + escHtml(ev.location) + '</span></div>' : '') +
        (ev.desc ? '<div class="detail-row"><span class="icon">📋</span><span class="detail-text">' + escHtml(ev.desc) + '</span></div>' : '') +
        '<div class="modal-actions">' +
          (ev.url ? '<a href="' + escapeAttr(ev.url) + '" target="_blank" rel="noopener" class="btn-primary">Visit Website →</a>' : '') +
          '<a href="' + gcalUrl + '" target="_blank" rel="noopener" class="btn-secondary">+ Google Calendar</a>' +
          '<button type="button" onclick="downloadIcs(' + idx + ')" class="btn-secondary">+ Apple/Outlook (.ics)</button>' +
        '</div>';
      document.getElementById('modalOverlay').classList.add('show');
    };
    window.closeModal = function() {
      const overlay = document.getElementById('modalOverlay');
      if (overlay) overlay.classList.remove('show');
    };

    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', init);
    else init();
  </script>

  <div class="not-prose max-w-3xl mx-auto mt-10">
    <div class="bg-bcc-cream border border-bcc-gray-200 rounded-2xl p-6">
      <p class="text-bcc-gray-700 leading-relaxed">
        This page lists upcoming community and political events across Bastrop County and nearby communities. For citations, prefer linking directly to the event source (shown in each event) and include the date.
      </p>
      <p class="text-sm text-bcc-gray-500 mt-3 italic">
        Last updated: {LAST_UPDATED}
      </p>
    </div>
  </div>

  {upcomingForSchema.length > 0 && (
    <script type="application/ld+json" set:html={eventsSchema} />
  )}
</PageLayout>
