      { title:"Bastrop Cornhole Classic", date:"2026-04-25", time:"10:00 AM", location:"Fisherman's Park, Bastrop", type:"community", org:"Visit Bastrop", desc:"Annual cornhole tournament at Fisherman's Park.", url:"https://www.visitbastrop.com/events/" },
