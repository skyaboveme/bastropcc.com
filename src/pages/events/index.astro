---
import PageLayout from '../../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';
import { generateEventsListSchema } from '../../utils/schema';

type PublicEvent = {
  title: string;
  date: string;
  location: string;
  description?: string;
  event_url?: string;
  org?: string;
};

const LAST_UPDATED = '2026-05-06';

const collectionEntries = await getCollection('events');
const JSON_EVENTS = collectionEntries.map((e) => ({
  title: e.data.title,
  date: e.data.date,
  time: e.data.time || '',
  endTime: e.data.endTime || '',
  location: e.data.location || '',
  desc: e.data.description || '',
  url: e.data.link || '',
  org: e.data.org || 'Other',
  type: (e.data.type as 'political' | 'community') || 'community',
  featured: e.data.featured === true,
}));

async function fetchPublicEvents(): Promise<PublicEvent[]> {
  try {
    const res = await fetch('https://bastropcc-api.communications-b08.workers.dev/api/v1/public/events');
    const json = await res.json();
    if (!json?.success || !Array.isArray(json?.data)) return [];
    return json.data as PublicEvent[];
  } catch {
    return [];
  }
}

const apiEvents = await fetchPublicEvents();
const now = new Date();
const todayMidnight = new Date(now.getFullYear(), now.getMonth(), now.getDate());
const upcomingForSchema = apiEvents
  .filter((e) => {
    const d = new Date(`${e.date}T00:00:00`);
    return Number.isFinite(d.valueOf()) && d >= todayMidnight;
  })
  .sort((a, b) => a.date.localeCompare(b.date))
  .slice(0, 25);

const eventsSchema = generateEventsListSchema(
  upcomingForSchema.map((e) => ({
    name: e.title,
    startDate: new Date(`${e.date}T00:00:00`).toISOString(),
    location: e.location,
    description: e.description || '',
    url: e.event_url || undefined,
    organizer: e.org || 'Bastrop County Conservatives',
  }))
);
---

<PageLayout
  title="Bastrop County Events Calendar — Community & Political Events"
  description="Your central calendar for Bastrop County events — community festivals, live music, political meetings, and more. Sourced from Visit Bastrop, Bastrop Chamber, and local organizations."
  heading="Bastrop County Events"
  subheading="Community & Political Events Calendar"
>
  <div class="cal-mag">
    <section class="hero-event" id="heroEvent" aria-label="Featured upcoming event">
      <div class="hero-skeleton">
        <div class="hero-skel-date"></div>
        <div class="hero-skel-title"></div>
        <div class="hero-skel-meta"></div>
      </div>
    </section>

    <div class="filter-bar" id="filterBar">
      <div class="search-row">
        <div class="search-wrap">
          <span class="search-icon" aria-hidden="true">🔍</span>
          <label for="eventSearch" class="visually-hidden">Search events</label>
          <input
            type="search"
            id="eventSearch"
            class="event-search"
            placeholder="Search by title, organizer, location, or description…"
            autocomplete="off"
            spellcheck="false"
          />
          <button type="button" class="search-clear" id="searchClear" aria-label="Clear search" hidden>✕</button>
        </div>
        <span class="result-count" id="resultCount" aria-live="polite"></span>
      </div>
      <div class="chip-row">
        <span class="chip-label">Type</span>
        <div class="chips" id="typeChips"></div>
      </div>
      <div class="chip-row">
        <span class="chip-label">Organizer</span>
        <div class="chips org-chips" id="orgChips"></div>
      </div>
    </div>

    <div class="event-list" id="eventList" role="list" aria-label="Upcoming events">
      <div class="loading-row">Loading events…</div>
    </div>

    <section class="submit-section" id="submit-event" aria-labelledby="submit-title">
      <h3 class="submit-title" id="submit-title">Submit an Event</h3>
      <p class="submit-desc">Have an event to share with Bastrop County? Submit it below and our team will review it for the calendar.</p>
      <form action="https://formsubmit.co/info@bastropcc.com" method="POST" id="event-submit-form" class="submit-form">
        <input type="hidden" name="_subject" value="BCC Website - New Event Submission" />
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_next" value="https://bastropcc.com/event-submitted" />
        <input type="text" name="_honey" style="display:none" />
        <div class="form-grid">
          <div class="form-full">
            <label for="event_title">Event Title <span class="req">*</span></label>
            <input type="text" id="event_title" name="EVENT_TITLE" required />
          </div>
          <div>
            <label for="event_date">Date <span class="req">*</span></label>
            <input type="date" id="event_date" name="EVENT_DATE" required />
          </div>
          <div>
            <label for="event_time">Time <span class="req">*</span></label>
            <input type="text" id="event_time" name="EVENT_TIME" placeholder="e.g. 6:00 PM" required />
          </div>
          <div class="form-full">
            <label for="event_location">Location <span class="req">*</span></label>
            <input type="text" id="event_location" name="EVENT_LOCATION" placeholder="Full address or venue name" required />
          </div>
          <div>
            <label for="event_type">Event Type</label>
            <select id="event_type" name="EVENT_TYPE">
              <option value="community">Community</option>
              <option value="political">Political</option>
            </select>
          </div>
          <div>
            <label for="event_org">Hosting Organization</label>
            <input type="text" id="event_org" name="EVENT_ORG" />
          </div>
          <div class="form-full">
            <label for="event_url">Event URL / Link</label>
            <input type="url" id="event_url" name="EVENT_URL" placeholder="https://" />
          </div>
          <div class="form-full">
            <label for="event_desc">Additional Details</label>
            <textarea id="event_desc" name="EVENT_DESC" rows="3"></textarea>
          </div>
        </div>
        <div class="form-actions">
          <button type="submit" class="submit-btn">Submit Event</button>
        </div>
      </form>
    </section>

    <div class="cal-footer">
      <p>Maintained by <a href="https://bastropcc.com">Bastrop County Conservatives</a> · Events sourced from partner organizations across Bastrop County</p>
      <p class="footer-note">BCC reserves the right to deny any individual(s) attendance at any meeting or event.</p>
    </div>

    <div class="modal-overlay" id="modalOverlay" role="dialog" aria-modal="true" aria-labelledby="modalTitle">
      <div class="modal" id="modal"></div>
    </div>
  </div>

  <style is:global>
    .cal-mag {
      --navy: #1a2b4a; --navy-mid: #243656; --gold: #c9a84c;
      --red: #b91c1c; --cream: #faf8f4; --white: #ffffff;
      --border: #e5e2db; --text: #1a2b4a; --text-dim: #6b7280;
      --radius: 10px; --shadow: 0 2px 12px rgba(0,0,0,0.08);
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      color: var(--text); line-height: 1.5; -webkit-font-smoothing: antialiased; width: 100%;
      max-width: 1080px; margin: 0 auto;
    }
    .cal-mag .visually-hidden {
      position: absolute !important; width: 1px; height: 1px; padding: 0; margin: -1px;
      overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0;
    }

    /* HERO */
    .cal-mag .hero-event {
      position: relative; background: linear-gradient(135deg, #1a2b4a 0%, #243656 100%);
      color: var(--white); border-radius: 14px; padding: 2.25rem 2rem; margin-bottom: 1.75rem;
      overflow: hidden; box-shadow: 0 8px 28px rgba(26, 43, 74, 0.18);
      border: 1px solid rgba(201, 168, 76, 0.25);
    }
    .cal-mag .hero-event::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 4px;
      background: linear-gradient(90deg, var(--gold) 0%, var(--red) 100%);
    }
    .cal-mag .hero-event::after {
      content: ''; position: absolute; right: -60px; top: -60px; width: 220px; height: 220px;
      background: radial-gradient(circle, rgba(201, 168, 76, 0.12) 0%, transparent 70%);
      pointer-events: none;
    }
    .cal-mag .hero-tag {
      display: inline-flex; align-items: center; gap: 6px; font-size: 0.65rem;
      letter-spacing: 0.18em; text-transform: uppercase; font-weight: 700;
      background: var(--gold); color: var(--navy); padding: 4px 12px; border-radius: 12px;
      margin-bottom: 1rem; position: relative; z-index: 1;
    }
    .cal-mag .hero-grid {
      display: grid; grid-template-columns: 110px 1fr; gap: 1.5rem; align-items: start;
      position: relative; z-index: 1;
    }
    .cal-mag .hero-date {
      text-align: center; padding: 0.75rem 0.5rem; background: rgba(255,255,255,0.08);
      border-radius: 10px; border: 1px solid rgba(201, 168, 76, 0.35);
    }
    .cal-mag .hero-date .h-month {
      font-size: 0.7rem; letter-spacing: 0.18em; text-transform: uppercase;
      font-weight: 700; color: var(--gold); margin-bottom: 0.15rem;
    }
    .cal-mag .hero-date .h-day {
      font-family: 'Playfair Display', 'Oswald', serif; font-weight: 700;
      font-size: 3rem; line-height: 1; color: var(--white);
    }
    .cal-mag .hero-date .h-weekday {
      font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase;
      color: rgba(255,255,255,0.7); margin-top: 0.3rem; font-weight: 600;
    }
    .cal-mag .hero-body { min-width: 0; }
    .cal-mag .hero-meta {
      display: flex; flex-wrap: wrap; gap: 0.4rem; margin-bottom: 0.6rem;
    }
    .cal-mag .hero-meta .badge {
      font-size: 0.65rem; padding: 3px 10px; border-radius: 10px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.06em;
    }
    .cal-mag .hero-meta .badge.org { background: rgba(255,255,255,0.15); color: var(--white); }
    .cal-mag .hero-meta .badge.political { background: #fde8e8; color: #991b1b; }
    .cal-mag .hero-meta .badge.community { background: #d1fae5; color: #065f46; }
    .cal-mag .hero-event h2 {
      font-family: 'Playfair Display', 'Oswald', serif; font-weight: 700;
      font-size: clamp(1.4rem, 2.4vw, 1.85rem); margin: 0 0 0.55rem; color: var(--white);
      line-height: 1.18; text-transform: none; letter-spacing: -0.005em;
    }
    .cal-mag .hero-where-when {
      font-size: 0.95rem; color: rgba(255,255,255,0.92); margin-bottom: 0.75rem;
    }
    .cal-mag .hero-where-when strong { color: var(--gold); font-weight: 700; }
    .cal-mag .hero-desc {
      color: rgba(255,255,255,0.85); font-size: 0.95rem; margin-bottom: 1.1rem;
      display: -webkit-box; -webkit-line-clamp: 3; line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
    }
    .cal-mag .hero-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .cal-mag .hero-actions a, .cal-mag .hero-actions button {
      display: inline-block; padding: 9px 18px; border-radius: 6px; font-size: 0.78rem;
      font-weight: 700; text-decoration: none; transition: all 0.2s; text-transform: uppercase;
      letter-spacing: 0.04em; cursor: pointer; border: 1px solid transparent; font-family: inherit;
    }
    .cal-mag .hero-actions .btn-primary { background: var(--gold); color: var(--navy); border-color: var(--gold); }
    .cal-mag .hero-actions .btn-primary:hover { background: #b89640; border-color: #b89640; }
    .cal-mag .hero-actions .btn-ghost {
      background: transparent; color: var(--white); border-color: rgba(255,255,255,0.35);
    }
    .cal-mag .hero-actions .btn-ghost:hover { background: rgba(255,255,255,0.12); border-color: var(--white); }

    .cal-mag .hero-skeleton .hero-skel-date,
    .cal-mag .hero-skeleton .hero-skel-title,
    .cal-mag .hero-skeleton .hero-skel-meta {
      height: 16px; background: rgba(255,255,255,0.15); border-radius: 4px; margin-bottom: 10px;
      animation: pulse 1.4s ease-in-out infinite;
    }
    .cal-mag .hero-skeleton .hero-skel-date { width: 80px; height: 60px; }
    .cal-mag .hero-skeleton .hero-skel-title { width: 70%; height: 28px; }
    .cal-mag .hero-skeleton .hero-skel-meta { width: 50%; }
    @keyframes pulse { 0%,100% { opacity: 0.6; } 50% { opacity: 1; } }

    /* FILTER BAR */
    .cal-mag .filter-bar {
      background: var(--cream); border: 1px solid var(--border); border-radius: var(--radius);
      padding: 1rem 1.1rem; margin-bottom: 1.5rem;
    }
    .cal-mag .search-row {
      display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem; margin-bottom: 0.85rem;
    }
    .cal-mag .search-wrap { position: relative; flex: 1 1 320px; display: flex; }
    .cal-mag .search-icon {
      position: absolute; left: 13px; top: 50%; transform: translateY(-50%);
      color: var(--text-dim); font-size: 0.85rem; pointer-events: none;
    }
    .cal-mag .event-search {
      width: 100%; padding: 10px 38px 10px 38px; border: 1px solid var(--border); border-radius: 22px;
      background: var(--white); font-size: 0.9rem; color: var(--text); font-family: inherit;
      transition: border-color 0.15s, box-shadow 0.15s; box-sizing: border-box;
    }
    .cal-mag .event-search::-webkit-search-cancel-button { -webkit-appearance: none; }
    .cal-mag .event-search:focus {
      outline: none; border-color: var(--navy); box-shadow: 0 0 0 3px rgba(26, 43, 74, 0.12);
    }
    .cal-mag .search-clear {
      position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
      background: var(--cream); border: 1px solid var(--border); color: var(--text-dim);
      width: 24px; height: 24px; border-radius: 50%; cursor: pointer; font-size: 0.7rem;
      display: flex; align-items: center; justify-content: center; transition: all 0.15s; padding: 0;
    }
    .cal-mag .search-clear:hover { background: var(--navy); color: var(--white); border-color: var(--navy); }
    .cal-mag .search-clear[hidden] { display: none; }
    .cal-mag .result-count {
      font-size: 0.72rem; color: var(--text-dim); font-weight: 600;
      text-transform: uppercase; letter-spacing: 0.05em; white-space: nowrap;
    }
    .cal-mag .result-count.has-query { color: var(--navy); }
    .cal-mag .result-count em { font-style: normal; color: var(--red); font-weight: 700; }

    .cal-mag .chip-row {
      display: flex; flex-wrap: wrap; align-items: center; gap: 0.5rem;
      padding-top: 0.6rem; margin-top: 0.4rem; border-top: 1px dashed var(--border);
    }
    .cal-mag .chip-label {
      font-size: 0.68rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em;
      color: var(--text-dim); white-space: nowrap; min-width: 70px;
    }
    .cal-mag .chips { display: flex; flex-wrap: wrap; gap: 0.4rem; flex: 1 1 auto; }
    .cal-mag .chip {
      display: inline-flex; align-items: center; gap: 6px; font-size: 0.72rem; padding: 5px 12px;
      border-radius: 14px; border: 1px solid var(--navy); background: var(--navy); color: var(--white);
      cursor: pointer; font-weight: 600; transition: all 0.15s; white-space: nowrap;
      font-family: inherit;
    }
    .cal-mag .chip:hover { background: var(--navy-mid); }
    .cal-mag .chip.active { background: var(--white); border-color: var(--border); color: var(--text-dim); }
    .cal-mag .chip.active:hover { border-color: var(--navy); color: var(--navy); }
    .cal-mag .chip .dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
    .cal-mag .chip.all-chip { background: var(--gold); border-color: var(--gold); color: var(--navy); }
    .cal-mag .chip.all-chip:hover { background: #b89640; border-color: #b89640; }
    .cal-mag .chip.all-chip.active { background: var(--white); border-color: var(--border); color: var(--text-dim); }
    .cal-mag .org-chips .chip { font-size: 0.68rem; padding: 4px 10px; }

    /* EVENT LIST (magazine) */
    .cal-mag .event-list { display: flex; flex-direction: column; gap: 0.5rem; }
    .cal-mag .loading-row { padding: 2rem; text-align: center; color: var(--text-dim); }
    .cal-mag .month-divider {
      display: flex; align-items: center; gap: 1rem; margin: 1.5rem 0 0.6rem; font-family: 'Playfair Display', 'Oswald', serif;
    }
    .cal-mag .month-divider:first-child { margin-top: 0; }
    .cal-mag .month-divider .month-name {
      font-size: 1.1rem; font-weight: 700; color: var(--navy);
      text-transform: uppercase; letter-spacing: 0.12em;
    }
    .cal-mag .month-divider .month-line {
      flex: 1; height: 1px; background: linear-gradient(90deg, var(--gold) 0%, transparent 100%);
    }
    .cal-mag .event-row {
      display: grid; grid-template-columns: 80px 1fr; gap: 1rem; padding: 0.85rem 1rem;
      background: var(--white); border: 1px solid var(--border); border-radius: var(--radius);
      cursor: pointer; transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
      animation: fadeSlide 0.3s ease both;
      text-align: left;
    }
    .cal-mag .event-row:hover {
      border-color: var(--navy); box-shadow: 0 4px 14px rgba(26, 43, 74, 0.08);
      transform: translateY(-1px);
    }
    .cal-mag .event-row.is-political { border-left: 4px solid var(--red); }
    .cal-mag .event-row.is-community { border-left: 4px solid #059669; }
    .cal-mag .ev-date {
      text-align: center; padding-top: 2px; border-right: 1px dashed var(--border); padding-right: 0.5rem;
    }
    .cal-mag .ev-date .ev-weekday {
      font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.12em;
      color: var(--text-dim); font-weight: 700; display: block;
    }
    .cal-mag .ev-date .ev-day {
      font-family: 'Playfair Display', 'Oswald', serif; font-weight: 800;
      font-size: 1.85rem; color: var(--navy); line-height: 1;
    }
    .cal-mag .ev-date .ev-mon {
      font-size: 0.62rem; text-transform: uppercase; letter-spacing: 0.12em;
      color: var(--text-dim); font-weight: 600; margin-top: 2px;
    }
    .cal-mag .ev-body { min-width: 0; }
    .cal-mag .ev-meta {
      display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 0.3rem; align-items: center;
    }
    .cal-mag .ev-meta .badge {
      font-size: 0.6rem; padding: 2px 8px; border-radius: 10px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.06em;
    }
    .cal-mag .ev-meta .badge.political { background: #fde8e8; color: #991b1b; }
    .cal-mag .ev-meta .badge.community { background: #d1fae5; color: #065f46; }
    .cal-mag .ev-meta .badge.org { background: var(--cream); border: 1px solid var(--border); color: var(--text-dim); }
    .cal-mag .ev-meta .badge.featured { background: var(--gold); color: var(--navy); }
    .cal-mag .ev-body h3 {
      font-family: 'Inter', sans-serif; font-size: 1.02rem; font-weight: 700;
      color: var(--navy); margin: 0 0 0.2rem; line-height: 1.3; letter-spacing: 0;
      text-transform: none;
    }
    .cal-mag .ev-body .ev-where-when {
      font-size: 0.82rem; color: var(--text-dim); display: flex; flex-wrap: wrap; gap: 0.5rem;
    }
    .cal-mag .ev-body .ev-where-when .ev-time { color: var(--red); font-weight: 700; }

    .cal-mag .empty-state {
      padding: 3rem 1rem; text-align: center; color: var(--text-dim);
      background: var(--cream); border: 1px dashed var(--border); border-radius: var(--radius);
    }
    .cal-mag .empty-state strong { display: block; font-size: 1.05rem; color: var(--navy); margin-bottom: 0.4rem; }

    /* MODAL */
    .cal-mag .modal-overlay {
      display: none; position: fixed; inset: 0; background: rgba(26, 43, 74, 0.65); z-index: 1000;
      backdrop-filter: blur(6px); justify-content: center; align-items: center; padding: 1.5rem;
    }
    .cal-mag .modal-overlay.show { display: flex; }
    .cal-mag .modal {
      background: var(--white); border: 1px solid var(--border); border-radius: 12px; max-width: 540px;
      width: 100%; padding: 2rem; position: relative; box-shadow: 0 8px 40px rgba(0,0,0,0.18);
      max-height: 85vh; overflow-y: auto; text-align: left; animation: fadeSlide 0.25s ease both;
    }
    .cal-mag .modal-close {
      position: absolute; top: 12px; right: 14px; background: none; border: none;
      color: var(--text-dim); font-size: 1.4rem; cursor: pointer;
    }
    .cal-mag .modal-close:hover { color: var(--red); }
    .cal-mag .modal h2 {
      font-family: 'Playfair Display', 'Oswald', serif; font-weight: 700; font-size: 1.35rem;
      color: var(--navy); margin-bottom: 0.5rem; padding-right: 2rem; line-height: 1.25;
      text-transform: none; letter-spacing: 0;
    }
    .cal-mag .modal .modal-meta { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-bottom: 1rem; }
    .cal-mag .modal .modal-meta .badge {
      font-size: 0.7rem; padding: 3px 10px; border-radius: 10px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.05em;
    }
    .cal-mag .modal .modal-meta .badge.org { background: var(--cream); border: 1px solid var(--border); color: var(--navy); }
    .cal-mag .modal .modal-meta .badge.political { background: #fde8e8; color: #991b1b; }
    .cal-mag .modal .modal-meta .badge.community { background: #d1fae5; color: #065f46; }
    .cal-mag .modal .detail-row {
      display: flex; gap: 0.6rem; align-items: flex-start; margin-bottom: 0.6rem; font-size: 0.95rem;
    }
    .cal-mag .modal .detail-row .icon {
      width: 20px; text-align: center; flex-shrink: 0; font-size: 0.95rem; margin-top: 1px;
    }
    .cal-mag .modal .detail-row .detail-text { color: var(--text); }
    .cal-mag .modal .detail-row .detail-text a { color: var(--red); text-decoration: underline; text-underline-offset: 2px; }
    .cal-mag .modal .detail-row .detail-text a:hover { color: var(--navy); }
    .cal-mag .modal-actions { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1.5rem; }
    .cal-mag .modal-actions a, .cal-mag .modal-actions button {
      display: inline-block; padding: 9px 18px; border-radius: 6px; font-size: 0.78rem;
      font-weight: 700; text-decoration: none; transition: all 0.2s; text-transform: uppercase;
      letter-spacing: 0.04em; cursor: pointer; border: 1px solid transparent; font-family: inherit;
    }
    .cal-mag .modal-actions .btn-primary { background: var(--red); color: var(--white); }
    .cal-mag .modal-actions .btn-primary:hover { background: #991b1b; }
