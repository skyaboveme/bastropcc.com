---
import PageLayout from '../layouts/PageLayout.astro';
import SectionHeading from '../components/ui/SectionHeading.astro';
import { Icon } from 'astro-icon/components';
---

<PageLayout 
  title="Who Represents You — Bastrop County Elected Officials"
  description="A complete directory of Bastrop County elected officials including Commissioners Court, Justice of the Peace, Constables, County Officers, and Bastrop ISD School Board."
  heading="Who Represents You"
  subheading="Your complete guide to Bastrop County's elected officials — who they are, how to reach them, and when they're up for re-election."
>

  <!-- Quick Jump Nav -->
  <div class="not-prose mb-16 flex flex-wrap justify-center gap-3">
    <a href="#commissioners" class="bg-bcc-navy text-white px-4 py-2 rounded-full text-sm font-bold hover:bg-bcc-red transition-colors">Commissioners Court</a>
    <a href="#county-officers" class="bg-bcc-navy text-white px-4 py-2 rounded-full text-sm font-bold hover:bg-bcc-red transition-colors">County Officers</a>
    <a href="#justice-peace" class="bg-bcc-navy text-white px-4 py-2 rounded-full text-sm font-bold hover:bg-bcc-red transition-colors">Justice of the Peace</a>
    <a href="#constables" class="bg-bcc-navy text-white px-4 py-2 rounded-full text-sm font-bold hover:bg-bcc-red transition-colors">Constables</a>
    <a href="#school-board" class="bg-bcc-navy text-white px-4 py-2 rounded-full text-sm font-bold hover:bg-bcc-red transition-colors">School Board</a>
    <a href="#state-federal" class="bg-bcc-navy text-white px-4 py-2 rounded-full text-sm font-bold hover:bg-bcc-red transition-colors">State & Federal</a>
  </div>

  <!-- Commissioners Court -->
  <section id="commissioners" class="mb-20 not-prose scroll-mt-20">
    <SectionHeading title="Commissioners Court" />
    <p class="text-bcc-gray-600 mb-8 max-w-3xl">The Commissioners Court is the governing body of Bastrop County. It sets the county tax rate, approves the budget, manages county infrastructure, and oversees all county operations. Regular meetings are held at the Bastrop County Courthouse.</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- County Judge -->
      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center gap-2 mb-1">
          <span class="bg-bcc-red text-white text-xs font-bold px-2 py-0.5 rounded-full">R</span>
          <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider">County Judge</span>
        </div>
        <h3 class="text-xl font-bold text-bcc-navy mb-3">Gregory Klaus</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:map-pin" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Bastrop County Courthouse</div>
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 332-7201</div>
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Up for re-election: 2026</div>
        </div>
      </div>

      <!-- Pct 1 -->
      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center gap-2 mb-1">
          <span class="bg-bcc-red text-white text-xs font-bold px-2 py-0.5 rounded-full">R</span>
          <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider">Commissioner, Pct. 1</span>
        </div>
        <h3 class="text-xl font-bold text-bcc-navy mb-3">Butch Carmack</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:map-pin" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Bastrop County Courthouse</div>
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 332-7207</div>
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Term: 2025–2028</div>
        </div>
      </div>

      <!-- Pct 2 -->
      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center gap-2 mb-1">
          <span class="bg-bcc-red text-white text-xs font-bold px-2 py-0.5 rounded-full">R</span>
          <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider">Commissioner, Pct. 2</span>
        </div>
        <h3 class="text-xl font-bold text-bcc-navy mb-3">Clara Beckett</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:map-pin" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Bastrop County Courthouse</div>
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 332-7208</div>
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Up for re-election: 2026</div>
        </div>
      </div>

      <!-- Pct 3 -->
      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center gap-2 mb-1">
          <span class="bg-bcc-red text-white text-xs font-bold px-2 py-0.5 rounded-full">R</span>
          <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider">Commissioner, Pct. 3</span>
        </div>
        <h3 class="text-xl font-bold text-bcc-navy mb-3">Mark Meuth</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:map-pin" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Bastrop County Courthouse</div>
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 332-7209</div>
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Term: 2025–2028</div>
        </div>
      </div>

      <!-- Pct 4 -->
      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center gap-2 mb-1">
          <span class="bg-bcc-red text-white text-xs font-bold px-2 py-0.5 rounded-full">R</span>
          <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider">Commissioner, Pct. 4</span>
        </div>
        <h3 class="text-xl font-bold text-bcc-navy mb-3">David Glass</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:map-pin" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Bastrop County Courthouse</div>
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 332-7210</div>
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Up for re-election: 2026</div>
        </div>
      </div>
    </div>
  </section>

  <!-- County Officers -->
  <section id="county-officers" class="mb-20 not-prose scroll-mt-20">
    <SectionHeading title="County Officers" />
    <p class="text-bcc-gray-600 mb-8 max-w-3xl">These county-wide elected officials manage critical government functions including law enforcement, elections, court records, property tax collection, and county administration.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <!-- Sheriff -->
      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center gap-2 mb-1">
          <span class="bg-bcc-red text-white text-xs font-bold px-2 py-0.5 rounded-full">R</span>
          <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider">Sheriff</span>
        </div>
        <h3 class="text-xl font-bold text-bcc-navy mb-3">Maurice Cook</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 549-5100</div>
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Term: 2025–2028</div>
        </div>
      </div>

      <!-- County Clerk -->
      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center gap-2 mb-1">
          <span class="bg-bcc-red text-white text-xs font-bold px-2 py-0.5 rounded-full">R</span>
          <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider">County Clerk</span>
        </div>
        <h3 class="text-xl font-bold text-bcc-navy mb-3">Krista Bartsch</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 332-7244</div>
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Up for re-election: 2026</div>
        </div>
      </div>

      <!-- District Clerk -->
      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center gap-2 mb-1">
          <span class="bg-bcc-red text-white text-xs font-bold px-2 py-0.5 rounded-full">R</span>
          <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider">District Clerk</span>
        </div>
        <h3 class="text-xl font-bold text-bcc-navy mb-3">Sarah Loucks</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 332-7234</div>
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Up for re-election: 2026</div>
        </div>
      </div>

      <!-- Tax Assessor -->
      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center gap-2 mb-1">
          <span class="bg-bcc-red text-white text-xs font-bold px-2 py-0.5 rounded-full">R</span>
          <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider">Tax Assessor-Collector</span>
        </div>
        <h3 class="text-xl font-bold text-bcc-navy mb-3">Ellen Owens</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:globe" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> <a href="https://bastroptac.com" target="_blank" class="text-bcc-red hover:underline">bastroptac.com</a></div>
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 581-7161</div>
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Up for re-election: 2026</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Justice of the Peace -->
  <section id="justice-peace" class="mb-20 not-prose scroll-mt-20">
    <SectionHeading title="Justice of the Peace" />
    <p class="text-bcc-gray-600 mb-8 max-w-3xl">Justices of the Peace preside over small claims courts, hear Class C misdemeanor cases, conduct inquests, perform marriages, and issue warrants. Each serves a four-year term.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider block mb-1">Precinct 1</span>
        <h3 class="text-lg font-bold text-bcc-navy mb-3">Judge Cindy Allen</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 332-7256</div>
        </div>
      </div>

      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider block mb-1">Precinct 2</span>
        <h3 class="text-lg font-bold text-bcc-navy mb-3">Judge Zachary Carter</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 281-5737</div>
        </div>
      </div>

      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider block mb-1">Precinct 3</span>
        <h3 class="text-lg font-bold text-bcc-navy mb-3">Judge Krystal Stabeno</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 332-7261</div>
        </div>
      </div>

      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider block mb-1">Precinct 4</span>
        <h3 class="text-lg font-bold text-bcc-navy mb-3">Judge Larry Dunne</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 332-7264</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Constables -->
  <section id="constables" class="mb-20 not-prose scroll-mt-20">
    <SectionHeading title="Constables" />
    <p class="text-bcc-gray-600 mb-8 max-w-3xl">Constables are elected law enforcement officers who serve civil process, provide courthouse security, and enforce the law within their precincts. Each serves a four-year term.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider block mb-1">Precinct 1</span>
        <h3 class="text-lg font-bold text-bcc-navy mb-3">Wayne Wood</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 332-7279</div>
        </div>
      </div>

      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider block mb-1">Precinct 2</span>
        <h3 class="text-lg font-bold text-bcc-navy mb-3">James L. Scoggins</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 281-5738</div>
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Term through: 2028</div>
        </div>
      </div>

      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider block mb-1">Precinct 3</span>
        <h3 class="text-lg font-bold text-bcc-navy mb-3">Tim Sparkman</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 332-7281</div>
        </div>
      </div>

      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider block mb-1">Precinct 4</span>
        <h3 class="text-lg font-bold text-bcc-navy mb-3">Joey Dzienowski</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 332-7282</div>
        </div>
      </div>
    </div>
  </section>

  <!-- School Board -->
  <section id="school-board" class="mb-20 not-prose scroll-mt-20">
    <SectionHeading title="Bastrop ISD Board of Trustees" />
    <p class="text-bcc-gray-600 mb-8 max-w-3xl">The Bastrop ISD Board of Trustees is the policy-making body for the school district. Seven members are elected at-large for three-year terms. The board governs a $196 million annual budget serving approximately 20,000 students. Elections are held the first Saturday in May.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider block mb-1">Place 7 · President</span>
        <h3 class="text-lg font-bold text-bcc-navy mb-3">Ashley Mutschink</h3>
        <div class="text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Term expires: 2028</div>
        </div>
      </div>

      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider block mb-1">Place 5 · Vice President</span>
        <h3 class="text-lg font-bold text-bcc-navy mb-3">Chris Dillon</h3>
        <div class="text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Term expires: 2028</div>
        </div>
      </div>

      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider block mb-1">Place 2 · Secretary</span>
        <h3 class="text-lg font-bold text-bcc-navy mb-3">Kellye Seekatz</h3>
        <div class="text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Term expires: 2027</div>
        </div>
      </div>

      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider block mb-1">Place 1</span>
        <h3 class="text-lg font-bold text-bcc-navy mb-3">Carol A. Armstrong</h3>
        <div class="text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Term expires: 2027</div>
        </div>
      </div>

      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider block mb-1">Place 3</span>
        <h3 class="text-lg font-bold text-bcc-navy mb-3">Josh Coy</h3>
        <div class="text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Term expires: 2026</div>
        </div>
      </div>

      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider block mb-1">Place 4</span>
        <h3 class="text-lg font-bold text-bcc-navy mb-3">Priscilla Ruiz</h3>
        <div class="text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Term expires: 2026</div>
        </div>
      </div>

      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider block mb-1">Place 6</span>
        <h3 class="text-lg font-bold text-bcc-navy mb-3">Dr. Matthew Mix</h3>
        <div class="text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:calendar" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> Term expires: 2028</div>
        </div>
      </div>
    </div>
  </section>

  <!-- State & Federal -->
  <section id="state-federal" class="mb-20 not-prose scroll-mt-20">
    <SectionHeading title="State & Federal Representatives" />
    <p class="text-bcc-gray-600 mb-8 max-w-3xl">Bastrop County residents are represented at the state and federal level by the following officials.</p>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
        <div class="flex items-center gap-2 mb-1">
          <span class="bg-bcc-red text-white text-xs font-bold px-2 py-0.5 rounded-full">R</span>
          <span class="text-xs text-bcc-gray-500 font-medium uppercase tracking-wider">U.S. Senator</span>
        </div>
        <h3 class="text-xl font-bold text-bcc-navy mb-3">Ted Cruz</h3>
        <div class="space-y-2 text-sm text-bcc-gray-600">
          <div class="flex items-center gap-2"><Icon name="lucide:globe" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> <a href="https://www.cruz.senate.gov" target="_blank" class="text-bcc-red hover:underline">cruz.senate.gov</a></div>
          <div class="flex items-center gap-2"><Icon name="lucide:phone" class="w-4 h-4 text-bcc-gold flex-shrink-0" /> (512) 916-5834</div>
        </div>
      </div>

      <div class="bg-white border border-bcc-gray-200 rounded-xl p-6 shadow-sm hover:shadow-md transition-shadow">
