---
import PageLayout from '../layouts/PageLayout.astro';
import { Icon } from 'astro-icon/components';
---

<PageLayout 
  title="Event Submitted — Bastrop County Conservatives"
  heading="Event Submitted"
  subheading="Thank you for submitting your event to the Conservative Coalition Calendar."
>

  <div class="not-prose max-w-2xl mx-auto text-center mb-16">

    <div class="w-20 h-20 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-8">
      <Icon name="lucide:calendar-check" class="w-10 h-10" />
    </div>

    <p class="text-lg text-bcc-gray-700 mb-6">
      Your event submission has been received. Our team will review the details to ensure they align with our calendar guidelines.
    </p>

    <p class="text-bcc-gray-600 mb-10">
      Once approved, your event will be automatically added to the calendar for the community to see. If we have any questions, we may reach out to you via the email you provided.
    </p>

    <div class="pt-4">
      <a href="/events" class="inline-block bg-bcc-navy text-white font-bold py-3 px-8 rounded-md hover:bg-bcc-red transition-colors">
        Return to Calendar
      </a>
    </div>

  </div>

</PageLayout>
